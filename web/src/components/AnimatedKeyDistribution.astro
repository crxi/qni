---
/**
 * AnimatedKeyDistribution — the key-distribution diagram, animated.
 *
 * Built from the same inline SVG as KeyDistributionDiagram, but the top
 * band (the symmetric-encryption flow) is driven by a beat machine — the
 * same pattern as AnimatedOpsPrimitives: each beat snaps the named
 * elements to a pose (transform + opacity) and CSS transitions handle the
 * in-betweens, so stepping backward animates the action in reverse.
 *
 * The story, beat by beat:
 *   0  a shared key is needed
 *   1  the key is shared — one copy to Alice, one to Bob
 *   2  Alice composes her plaintext message
 *   3  Alice encrypts — her padlock closes, plaintext → ciphertext
 *   4  the ciphertext crosses the public channel past Eve
 *   5  Bob decrypts — his padlock opens, ciphertext → plaintext
 *   6  Bob reads the original message
 *
 * The three-routes panels (step 3) are static throughout. Reduced-motion
 * jumps to the final beat and stays there.
 */
interface Props {
  /** figcaption etc. passed as children */
}
---

<figure class="zfig kd-fig" data-kd-figure>
  <div class="zfig__toolbar">
    <span class="zfig__phase" data-kd-phase aria-live="polite">Shared key needed</span>
    <div class="zfig__playback" role="group" aria-label="Animation playback controls">
      <button class="zfig__btn" type="button" data-kd-back aria-label="Step back" title="Step back">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6 5v14h2V5zM20 5L9 12l11 7z" fill="currentColor"/></svg>
      </button>
      <button class="zfig__btn" type="button" data-kd-play aria-label="Pause" title="Play / pause">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor"/></svg>
      </button>
      <button class="zfig__btn" type="button" data-kd-fwd aria-label="Step forward" title="Step forward">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M16 5v14h2V5zM4 5v14l11-7z" fill="currentColor"/></svg>
      </button>
      <button class="zfig__btn zfig__btn--speed" type="button" data-kd-speed aria-label="Playback speed" title="Playback speed">1×</button>
    </div>
    <button class="zfig__btn" type="button" data-kd-download aria-label="Download this figure as PNG" title="Download PNG (2K)">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="zfig__btn" type="button" data-kd-fullscreen aria-label="View this animation full-screen" title="Full screen">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M4 10V4h6M20 10V4h-6M4 14v6h6M20 14v6h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <svg class="kd" data-kd-svg viewBox="0 0 960 730" role="img"
       aria-label="Animated: Alice and Bob share a secret key, Alice encrypts a message into ciphertext, it crosses the public channel past Eve, and Bob decrypts it back to the original message.">
    <title>Symmetric encryption with a shared key — encrypt, transmit, decrypt</title>

    <!-- ============ 1 · SYMMETRIC ENCRYPTION (animated) ============ -->
    <circle class="kd-badge" cx="32" cy="26" r="12" />
    <text class="kd-badge-n" x="32" y="30">1</text>
    <text class="kd-h-title" x="54" y="31">Symmetric encryption — fast, once Alice and Bob share a key K</text>

    <!-- Alice / Bob / Eve (static) -->
    <use href="#om-alice" x="42" y="40" width="60" height="60" />
    <text class="kd-node-l" x="72" y="116">Alice</text>
    <use href="#om-bob" x="858" y="40" width="60" height="60" />
    <text class="kd-node-l" x="888" y="116">Bob</text>
    <use href="#om-eve" x="450" y="40" width="60" height="60" />
    <g transform="translate(445,76)"><use href="#kd-magnifier" /></g>
    <text class="kd-node-l" x="480" y="116">Eve</text>
    <!-- frustration burst — pops when Eve reads the scrambled copy -->
    <g data-name="evemad" transform="translate(515,49)" opacity="0"><use class="kd-anger" href="#om-anger" x="-13" y="-13" width="26" height="26" /></g>

    <!-- faint guide stubs from each party down to its padlock -->
    <line class="kd-plain" x1="72" y1="126" x2="72" y2="158" />
    <line class="kd-plain" x1="888" y1="126" x2="888" y2="158" />

    <!-- public channel between the padlocks -->
    <line class="kd-pub" x1="84" y1="172" x2="876" y2="172" />
    <text class="kd-pub-l" x="232" y="160">public channel</text>

    <!-- key-operating glow — flares behind the lock at encrypt / decrypt -->
    <g data-name="glowA" transform="translate(72,193)" opacity="0"><circle class="kd-glow" cx="0" cy="0" r="44" fill="url(#kd-glow)" /></g>
    <g data-name="glowB" transform="translate(888,193)" opacity="0"><circle class="kd-glow" cx="0" cy="0" r="44" fill="url(#kd-glow)" /></g>

    <!-- padlocks — crossfade open/closed pairs, one per party -->
    <g data-name="lockA-open"   transform="translate(72,172)"><use href="#kd-lock-open" /></g>
    <g data-name="lockA-closed" transform="translate(72,172)" opacity="0"><use href="#kd-lock" /></g>
    <g data-name="lockB-open"   transform="translate(888,172)"><use href="#kd-lock-open" /></g>
    <g data-name="lockB-closed" transform="translate(888,172)" opacity="0"><use href="#kd-lock" /></g>
    <text class="kd-tiny" x="72" y="226">encrypt</text>
    <text class="kd-tiny" x="888" y="226">decrypt</text>

    <!-- shared key K — central key splits into two halves, one to each lock -->
    <line class="kd-keyrail" x1="72" y1="186" x2="72" y2="230" />
    <line class="kd-keyrail" x1="888" y1="186" x2="888" y2="230" />
    <line class="kd-keyrail" x1="72" y1="230" x2="442" y2="230" />
    <line class="kd-keyrail" x1="518" y1="230" x2="888" y2="230" />
    <text class="kd-key-l" x="480" y="254">shared secret key K</text>
    <g data-name="key"  transform="translate(480,230)"><use href="#kd-key" /></g>
    <!-- key halves follow the dashed rail out along the channel, then turn up
         (offset-rotate: auto) so they finish vertical, inserted into the lock -->
    <g data-name="keyA" style="offset-path:path('M 480 230 L 92 230 Q 72 230 72 210 L 72 200')" opacity="0"><use href="#kd-key" /></g>
    <g data-name="keyB" style="offset-path:path('M 480 230 L 868 230 Q 888 230 888 210 L 888 200')" opacity="0"><use href="#kd-key" /></g>

    <!-- travelling message / ciphertext tokens (text re-rolled each cycle) -->
    <g data-name="msg" transform="translate(72,140)">
      <rect class="kd-msg-doc" x="-29" y="-11" width="58" height="22" rx="3" />
      <text class="kd-msg-l" data-msg-text x="0" y="4">Hello!</text>
    </g>
    <g data-name="cipher" transform="translate(115,172)" opacity="0">
      <rect class="kd-ct-box" x="-33" y="-11" width="66" height="22" rx="4" />
      <text class="kd-ct-l" data-cipher-text x="0" y="4">K$9@mZ</text>
    </g>
    <!-- Eve lifts a copy off the wire — same scrambled bytes, unreadable -->
    <g data-name="evecopy" transform="translate(480,172)" opacity="0">
      <rect class="kd-ct-box kd-copy-box" x="-33" y="-11" width="66" height="22" rx="4" />
      <text class="kd-ct-l" data-evecopy-text x="0" y="4">K$9@mZ</text>
    </g>
    <!-- Bob's delivered plaintext, shown only in the downloaded poster frame -->
    <g data-name="msgB" transform="translate(888,140)" opacity="0">
      <rect class="kd-msg-doc" x="-29" y="-11" width="58" height="22" rx="3" />
      <text class="kd-msg-l" data-msgb-text x="0" y="4">Hello!</text>
    </g>

    <!-- ============ 2 · KEY DISTRIBUTION ============ -->
    <circle class="kd-badge" cx="32" cy="286" r="12" />
    <text class="kd-badge-n" x="32" y="290">2</text>
    <text class="kd-h-title" x="54" y="291">Key distribution — the hard part</text>
    <text class="kd-prob-l" x="54" y="315">Get that same key K to both sides over a</text>
    <text class="kd-prob-l" x="54" y="333">public network — without Eve obtaining a copy.</text>

    <!-- ============ 3 · THREE WAYS (static) ============ -->
    <circle class="kd-badge" cx="32" cy="362" r="12" />
    <text class="kd-badge-n" x="32" y="366">3</text>
    <text class="kd-h-title" x="54" y="367">Three ways to distribute that key</text>
    <line class="kd-up" x1="480" y1="264" x2="480" y2="396" />
    <line class="kd-bus" x1="160" y1="380" x2="800" y2="380" />
    <line class="kd-up" x1="160" y1="380" x2="160" y2="396" />
    <line class="kd-up" x1="800" y1="380" x2="800" y2="396" />

    <g transform="translate(0,48)">
    <g class="kd-panel kd-panel--warn">
      <rect class="kd-panel-bg" x="15" y="348" width="290" height="320" rx="10" />
      <rect class="kd-panel-bar" x="15" y="348" width="5" height="320" />
      <text class="kd-p-kicker" x="36" y="378">CLASSICAL PUBLIC-KEY</text>
      <text class="kd-p-title" x="36" y="404">RSA · ECDH</text>
      <line class="kd-rule" x1="36" y1="420" x2="284" y2="420" />
      <text class="kd-p-body" x="36" y="444">Both sides agree a key by</text>
      <text class="kd-p-body" x="36" y="462">exchanging public values over</text>
      <text class="kd-p-body" x="36" y="480">the same public channel.</text>
      <text class="kd-p-tag" x="36" y="514">secures on ▸</text>
      <text class="kd-p-body" x="36" y="532">computational hardness —</text>
      <text class="kd-p-body" x="36" y="550">factoring, discrete log</text>
      <g transform="translate(36,588)"><use href="#kd-chip-x" /></g>
      <text class="kd-p-status" x="62" y="604">Broken by a cryptographically-</text>
      <text class="kd-p-status" x="62" y="622">relevant quantum computer (Shor)</text>
    </g>
    <g class="kd-panel kd-panel--acc">
      <rect class="kd-panel-bg" x="335" y="348" width="290" height="320" rx="10" />
      <rect class="kd-panel-bar" x="335" y="348" width="5" height="320" />
      <text class="kd-p-kicker" x="356" y="378">POST-QUANTUM CRYPTO</text>
      <text class="kd-p-title" x="356" y="404">ML-KEM (FIPS 203)</text>
      <line class="kd-rule" x1="356" y1="420" x2="604" y2="420" />
      <text class="kd-p-body" x="356" y="444">Same public-channel key</text>
      <text class="kd-p-body" x="356" y="462">agreement, rebuilt on a</text>
      <text class="kd-p-body" x="356" y="480">lattice problem.</text>
      <text class="kd-p-tag" x="356" y="514">secures on ▸</text>
      <text class="kd-p-body" x="356" y="532">computational hardness —</text>
      <text class="kd-p-body" x="356" y="550">module lattices (MLWE)</text>
      <g transform="translate(356,588)"><use href="#kd-chip-v" /></g>
      <text class="kd-p-status" x="382" y="604">No known quantum</text>
      <text class="kd-p-status" x="382" y="622">attack; a software upgrade</text>
    </g>
    <g class="kd-panel kd-panel--q">
      <rect class="kd-panel-bg" x="655" y="348" width="290" height="320" rx="10" />
      <rect class="kd-panel-bar" x="655" y="348" width="5" height="320" />
      <text class="kd-p-kicker" x="676" y="378">QUANTUM KEY DISTRIBUTION</text>
      <text class="kd-p-title" x="676" y="404">QKD — BB84</text>
      <line class="kd-rule" x1="676" y1="420" x2="924" y2="420" />
      <text class="kd-p-body" x="676" y="444">Key bits carried on single</text>
      <text class="kd-p-body" x="676" y="462">photons over a quantum</text>
      <text class="kd-p-body" x="676" y="480">channel; sifted over a public</text>
      <text class="kd-p-body" x="676" y="498">channel.</text>
      <text class="kd-p-tag" x="676" y="528">secures on ▸</text>
      <text class="kd-p-body" x="676" y="546">physics — no-cloning,</text>
      <text class="kd-p-body" x="676" y="564">measurement disturbs</text>
      <g transform="translate(676,596)"><use href="#kd-chip-v" /></g>
      <text class="kd-p-status" x="702" y="612">Eavesdropping raises the</text>
      <text class="kd-p-status" x="702" y="630">error rate → it is detected</text>
    </g>
    </g>

    <!-- ============ defs ============ -->
    <defs>
      <symbol id="om-alice" viewBox="0 0 72 72">
        <path fill="#92D3F5" d="M17,61v-4c0-5,5-9,10-9c6,5,12,5,18,0c5,0,10,4,10,9v4"/>
