        <path fill="#ea5a47" d="m22.167,35.9999c.0971-12.6769-8.1349-16.2848-10.1261-17.4376-.952-.5512-1.3186-.2021-.8146.7756,0,0,5.0637,8.369,5.0637,16.662s-5.0637,16.6619-5.0637,16.6621c-.504.9777-.1374,1.3268.8146.7756,1.9912-1.1528,10.2232-4.7607,10.1261-17.4377"/>
        <path fill="none" stroke="#000" stroke-linecap="round" stroke-miterlimit="10" stroke-width="2" d="m36,16.54c-8.293,0-16.662-4.3137-16.662-4.3137-.9777-.504-1.3268-.1374-.7757.8146,0,0,5.9136,10.2144,17.4377,10.1261,11.5242.0883,17.4377-10.1261,17.4377-10.1261.5512-.952.2021-1.3186-.7757-.8146,0,0-8.3689,4.3137-16.662,4.3137Z"/>
