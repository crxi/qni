<script is:inline>
(function () {
  function initFigure(fig) {
    var svg = fig.querySelector("svg[data-kd-svg]");
    if (!svg) return null;
    function byName(n) { return svg.querySelector('[data-name="' + n + '"]'); }

    var TOTAL = 9;            // beats 0..8
    var BEAT_MS = 1440;       // 25% slower than the first cut
    var PAUSE_END_MS = 2125;
    // per-beat hold time; the Eve approach (4) and copy (5) linger.
    var DUR = [BEAT_MS, BEAT_MS, BEAT_MS, BEAT_MS, 1950, 1550, BEAT_MS, BEAT_MS, PAUSE_END_MS];
    var rm = window.matchMedia("(prefers-reduced-motion: reduce)");

    // Alice's plaintext is a real 6-character word; the ciphertext is a
    // random 6-character printable-ASCII string. Both re-roll each cycle.
    var WORDS = ["Hello!", "Friday", "Attack", "Coffee", "Secret", "Photon",
                 "Cipher", "Rocket", "Banana", "Garden", "Submit", "Wallet"];
    var ASCII = [];
    for (var a = 33; a <= 126; a++) ASCII.push(String.fromCharCode(a));
    function pickMessage() {
      var w = WORDS[Math.floor(Math.random() * WORDS.length)];
      var c = "";
      for (var i = 0; i < 6; i++) c += ASCII[Math.floor(Math.random() * ASCII.length)];
      var mt = svg.querySelector("[data-msg-text]");
      var ct = svg.querySelector("[data-cipher-text]");
      var ec = svg.querySelector("[data-evecopy-text]");
      if (mt) mt.textContent = w;
      if (ct) ct.textContent = c;
      if (ec) ec.textContent = c;   // Eve's copy is the same scrambled bytes
    }

    var PHASE = [
      "Shared key needed",
      "Key shared with both",
      "Compose message",
      "Encrypt — padlock closes",
      "Ciphertext reaches Eve",
      "Eve copies it — but it's scrambled",
      "Ciphertext continues to Bob",
      "Decrypt — padlock opens",
      "Message delivered",
    ];

    // Per-beat poses: [x, y, opacity] for each travelling element.
    var P = {
      key:     [[480,230,1],[480,230,0],[480,230,0],[480,230,0],[480,230,0],[480,230,0],[480,230,0],[480,230,0],[480,230,0]],
      msg:[[72,140,1],[72,140,1],[72,168,1],[72,168,0],[72,168,0],[72,168,0],[888,168,0],[888,168,1],[888,140,1]],
      cipher:  [[115,172,0],[115,172,0],[115,172,0],[115,172,1],[480,172,1],[480,172,1],[845,172,1],[845,172,0],[845,172,0]],
      evecopy: [[480,172,0],[480,172,0],[480,172,0],[480,172,0],[480,172,0],[480,140,1],[480,140,1],[480,140,1],[480,140,1]],
    };

    function setNode(name, p) {
      var g = byName(name);
      if (!g) return;
      g.style.transform = "translate(" + p[0] + "px," + p[1] + "px)";
      g.style.opacity = String(p[2]);
    }
    function setOpacity(name, o) {
      var g = byName(name);
      if (g) g.style.opacity = String(o);
    }

    function applyBeat(b) {
      // ciphertext eases differently around Eve: decelerate as it reaches
      // her (4), speed back up as it leaves (6).
      var cipher = byName("cipher");
      if (cipher) {
        if (b === 4) {
          cipher.style.transitionDuration = "1600ms, 550ms";
          cipher.style.transitionTimingFunction = "cubic-bezier(0.1,0.75,0.15,1), ease";
        } else if (b === 6) {
          cipher.style.transitionDuration = "1050ms, 550ms";
          cipher.style.transitionTimingFunction = "cubic-bezier(0.45,0,0.9,0.55), ease";
        } else {
          cipher.style.transitionDuration = "";
          cipher.style.transitionTimingFunction = "";
        }
      }
      Object.keys(P).forEach(function (n) { setNode(n, P[n][b]); });
      // key halves slide out along the rail (offset-path) from beat 1
      ["keyA", "keyB"].forEach(function (n) {
        var g = byName(n);
        if (!g) return;
        g.style.offsetDistance = (b >= 1) ? "100%" : "0%";
        g.style.opacity = (b >= 1) ? "1" : "0";
        // stay flat at the lock; turn vertical (insert) only when the message
        // arrives to be locked (Alice, beat 3) / unlocked (Bob, beat 7)
        var inserted = (n === "keyA") ? (b >= 3) : (b >= 7);
        g.style.offsetRotate = inserted ? "-90deg" : "0deg";
      });
      setOpacity("lockA-open",   b < 3 ? 1 : 0);
      setOpacity("lockA-closed", b >= 3 ? 1 : 0);
      setOpacity("lockB-open",   (b <= 5 || b >= 7) ? 1 : 0);
      setOpacity("lockB-closed", (b === 6) ? 1 : 0);
      setOpacity("evemad",       (b >= 5) ? 1 : 0);
      setOpacity("glowA",        (b === 3) ? 1 : 0);   // key locks Alice's box
      setOpacity("glowB",        (b === 7) ? 1 : 0);   // key opens Bob's box
      var ph = fig.querySelector("[data-kd-phase]");
      if (ph) ph.textContent = PHASE[b] || "";
    }

    var beat = 0;
    var playing = false;
    var timer = null;
    var speed = 1.0;
    var SPEEDS = [0.5, 0.75, 1.0];

    function apply() { applyBeat(beat); updatePlay(); }
    function step(d) { beat = Math.max(0, Math.min(TOTAL - 1, beat + d)); apply(); }
    function pause() { playing = false; if (timer) clearTimeout(timer); timer = null; updatePlay(); }
    function play() {
      if (rm.matches) { beat = TOTAL - 1; apply(); return; }
      playing = true;
      if (beat >= TOTAL - 1) beat = 0;
      apply();
      schedule();
    }
    function schedule() {
      if (!playing) return;
      var atEnd = beat >= TOTAL - 1;
      timer = setTimeout(function () {
        if (atEnd) restartCycle();
        else { beat += 1; apply(); }
        schedule();
      }, DUR[beat] / speed);
    }
    // Loop the cycle without animating the delivered message flying back to
    // Alice — snap the movers home with transitions off, then re-roll the
    // message so Alice simply starts a fresh one.
    function restartCycle() {
      var movers = ["msg", "cipher", "keyA", "keyB", "key", "evecopy", "evemad"].map(byName).filter(Boolean);
      movers.forEach(function (g) { g.style.transition = "none"; });
      pickMessage();
      beat = 0;
      applyBeat(0);
      movers.forEach(function (g) { void g.getBoundingClientRect(); });
      requestAnimationFrame(function () {
        movers.forEach(function (g) { g.style.transition = ""; });
      });
      updatePlay();
    }
    function cycleSpeed() {
      speed = SPEEDS[(SPEEDS.indexOf(speed) + 1) % SPEEDS.length];
      var b = fig.querySelector("[data-kd-speed]");
      if (b) b.textContent = (speed === 1.0 ? "1×" : speed + "×");
      if (playing && timer) { clearTimeout(timer); schedule(); }
    }
    function updatePlay() {
      var b = fig.querySelector("[data-kd-play]");
      if (!b) return;
      b.setAttribute("aria-label", playing ? "Pause" : "Play");
      b.innerHTML = playing
        ? '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor"/></svg>'
        : '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M7 4v16l13-8z" fill="currentColor"/></svg>';
    }

    // The download is a fixed "poster" frame rather than whatever beat is
    // mid-flight: plaintext at both ends, ciphertext under Eve, key shared.
    function posePoster(root) {
      function setN(name, x, y, o) {
        var g = root.querySelector('[data-name="' + name + '"]');
        if (g) g.setAttribute("style", (g.getAttribute("style") || "") +
          ";transform:translate(" + x + "px," + y + "px);opacity:" + o + ";");
      }
      function setO(name, o) {
        var g = root.querySelector('[data-name="' + name + '"]');
        if (g) g.setAttribute("style", (g.getAttribute("style") || "") + ";opacity:" + o + ";");
      }
      var mt = root.querySelector("[data-msg-text]");
      var mb = root.querySelector("[data-msgb-text]");
      if (mt && mb) mb.textContent = mt.textContent;   // Bob's plaintext = Alice's
      setN("msg", 72, 140, 1);
      setN("msgB", 888, 140, 1);
      setN("cipher", 480, 172, 1);
      // keys rest at the locks (override the motion path with a plain transform)
      var kA = root.querySelector('[data-name="keyA"]');
      var kB = root.querySelector('[data-name="keyB"]');
      if (kA) kA.setAttribute("style", (kA.getAttribute("style") || "") + ";offset-path:none;transform:translate(72px,200px) rotate(-90deg);opacity:1;");
      if (kB) kB.setAttribute("style", (kB.getAttribute("style") || "") + ";offset-path:none;transform:translate(888px,200px) rotate(-90deg);opacity:1;");
      setN("key", 480, 230, 0);
      setO("evecopy", 0);
      setO("evemad", 0);
      setO("glowA", 0); setO("glowB", 0);
      setO("lockA-open", 0); setO("lockA-closed", 1);
      setO("lockB-open", 1); setO("lockB-closed", 0);
    }

    // ── PNG download (rasterise a poster frame with computed colours) ──────
    function downloadPNG() {
      var clone = svg.cloneNode(true);
      var PROPS = ["fill","stroke","stroke-width","stroke-dasharray","stroke-linecap",
        "stroke-linejoin","opacity","fill-opacity","stroke-opacity","font-family",
        "font-size","font-weight","text-anchor","letter-spacing","transform"];
      var orig = svg.querySelectorAll("*");
      var cl = clone.querySelectorAll("*");
      for (var i = 0; i < orig.length; i++) {
        var cs = window.getComputedStyle(orig[i]);
        var s = "";
        for (var j = 0; j < PROPS.length; j++) {
          var v = cs.getPropertyValue(PROPS[j]);
          if (v && v !== "none" || PROPS[j] === "fill" || PROPS[j] === "stroke") s += PROPS[j] + ":" + v + ";";
        }
        cl[i].setAttribute("style", s);
      }
      posePoster(clone);
      var vb = svg.viewBox.baseVal;
      var scale = 2200 / vb.width;
      var W = Math.round(vb.width * scale), H = Math.round(vb.height * scale);
      clone.setAttribute("width", W);
      clone.setAttribute("height", H);
      var xml = new XMLSerializer().serializeToString(clone);
      var img = new Image();
      img.onload = function () {
        var c = document.createElement("canvas");
        c.width = W; c.height = H;
        var ctx = c.getContext("2d");
        var bg = window.getComputedStyle(document.body).getPropertyValue("--card-bg") || "#ffffff";
        ctx.fillStyle = bg.trim() || "#ffffff";
        ctx.fillRect(0, 0, W, H);
        ctx.drawImage(img, 0, 0, W, H);
        c.toBlob(function (blob) {
          if (!blob) return;
          var a = document.createElement("a");
          a.href = URL.createObjectURL(blob);
          a.download = "qnetinfo-key-distribution.png";
          document.body.appendChild(a); a.click(); a.remove();
          setTimeout(function () { URL.revokeObjectURL(a.href); }, 2000);
        }, "image/png");
      };
      img.src = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(xml);
    }

    // ── wire controls ──────────────────────────────────────────────────────
    var back = fig.querySelector("[data-kd-back]");
    var fwd = fig.querySelector("[data-kd-fwd]");
    var pp = fig.querySelector("[data-kd-play]");
    var sp = fig.querySelector("[data-kd-speed]");
    var dl = fig.querySelector("[data-kd-download]");
    if (back) back.addEventListener("click", function () { pause(); step(-1); });
    if (fwd) fwd.addEventListener("click", function () { pause(); step(1); });
    if (pp) pp.addEventListener("click", function () { if (playing) pause(); else play(); });
    if (sp) sp.addEventListener("click", cycleSpeed);
    if (dl) dl.addEventListener("click", downloadPNG);

    pickMessage();
    apply();
    if (rm.matches) { beat = TOTAL - 1; apply(); }
    else { setTimeout(play, 120); }

    return { teardown: pause };
  }

  function openFullScreen(srcFig) {
    var dialog = document.createElement("dialog");
    dialog.className = "kd-fullscreen";
    var clone = srcFig.cloneNode(true);
    delete clone.dataset.kdInited;
    var fsBtn = clone.querySelector("[data-kd-fullscreen]");
    if (fsBtn) {
      var close = document.createElement("button");
      close.type = "button";
      close.className = fsBtn.className;
      close.setAttribute("aria-label", "Close full-screen view");
      close.setAttribute("title", "Close");
      close.innerHTML = '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6 6l12 12M18 6l-12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';
      close.addEventListener("click", function () { dialog.close(); });
      fsBtn.parentNode.replaceChild(close, fsBtn);
    }
    dialog.appendChild(clone);
    document.body.appendChild(dialog);
    var handle = initFigure(clone);
    function destroy() { if (handle && handle.teardown) handle.teardown(); dialog.remove(); }
    dialog.addEventListener("close", destroy);
    dialog.addEventListener("click", function (e) { if (e.target === dialog) dialog.close(); });
    dialog.showModal();
  }

  document.querySelectorAll("[data-kd-figure]").forEach(function (fig) {
    if (fig.dataset.kdInited) return;
    fig.dataset.kdInited = "1";
    initFigure(fig);
  });
  document.addEventListener("click", function (e) {
    var btn = e.target && e.target.closest && e.target.closest("[data-kd-fullscreen]");
    if (!btn) return;
    var fig = btn.closest("[data-kd-figure]");
    if (fig) openFullScreen(fig);
  });
})();
</script>

<style>
  .zfig {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    display: grid;
    gap: var(--space-2);
  }
  .zfig__toolbar { display: flex; gap: 6px; justify-content: flex-end; align-items: center; flex-wrap: wrap; }
  .zfig__phase {
    margin-right: auto;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }
  .zfig__playback { display: flex; gap: 4px; }
  .zfig__btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 32px; height: 32px; padding: 0 6px;
    color: var(--color-text); background: var(--color-surface-2);
    border: 1px solid var(--card-border); border-radius: var(--radius-sm);
    cursor: pointer; text-decoration: none; font-size: 14px; line-height: 1;
  }
  .zfig__btn:hover { background: var(--color-surface); }
  .zfig__btn:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .kd { width: 100%; height: auto; display: block; font-family: var(--font-sans, system-ui, sans-serif); }

  /* animated travelling elements — CSS transitions fill in between beats */
  .kd [data-name] {
    transition: transform 975ms cubic-bezier(0.4, 0, 0.2, 1), opacity 550ms ease;
  }
  /* key halves travel along the rail via a motion path, not a straight line */
  .kd [data-name="keyA"], .kd [data-name="keyB"] {
    offset-rotate: 0deg;
    transition: offset-distance 1150ms cubic-bezier(0.4, 0, 0.2, 1),
                offset-rotate 620ms cubic-bezier(0.34, 1.3, 0.64, 1), opacity 550ms ease;
  }

  .kd-badge   { fill: var(--color-text); }
  .kd-badge-n { fill: var(--color-bg); font-size: 14px; font-weight: 700; text-anchor: middle; }
  .kd-h-title { fill: var(--color-text); font-size: 15px; font-weight: 700; }
  .kd-tiny   { fill: var(--color-text-mute); font-size: 10.5px; text-anchor: middle; }
  .kd-node-l { fill: var(--color-text); font-size: 13px; font-weight: 600; text-anchor: middle; }

  .kd-plain   { stroke: var(--color-rule); stroke-width: 2; }
  .kd-msg-doc { fill: var(--color-bg); stroke: var(--color-rule); stroke-width: 1.2; }
  .kd-msg-l   { fill: var(--color-text); font-size: 11.5px; font-weight: 600; text-anchor: middle; }

  /* coloured ciphertext token — random printable-ASCII, monospace */
  .kd-ct-box { fill: #5b53b0; stroke: #423a93; stroke-width: 1; }
  .kd-ct-l   { fill: #ffffff; font-size: 11.5px; font-weight: 700; text-anchor: middle; font-family: var(--font-mono, monospace); letter-spacing: 0.5px; }
  /* Eve's intercepted copy — dashed border marks it as a duplicate */
  .kd-copy-box { fill: #6f67c4; stroke: #e6e3f7; stroke-width: 1.3; stroke-dasharray: 3 2; }

  /* frustration burst over Eve — a small agitated wiggle. The glyph is
     centred at its group's origin, so rotate/scale pivot in place. */
  .kd-anger { transform-origin: 0 0; animation: kd-anger 0.46s ease-in-out infinite alternate; }
  @keyframes kd-anger {
    from { transform: scale(0.92) rotate(-7deg); }
    to   { transform: scale(1.12) rotate(7deg); }
  }
  @media (prefers-reduced-motion: reduce) { .kd-anger { animation: none; } }

  /* key-operating glow — breathes while the lock is being worked */
  .kd-glow { transform-origin: 0 0; animation: kd-glow-pulse 0.85s ease-in-out infinite alternate; }
  @keyframes kd-glow-pulse { from { transform: scale(0.78); } to { transform: scale(1.12); } }
  @media (prefers-reduced-motion: reduce) { .kd-glow { animation: none; } }

  .kd-pub    { stroke: var(--color-rule); stroke-width: 2; }
  .kd-pub-l  { fill: var(--color-text-mute); font-size: 11px; text-anchor: middle; }

  .kd-mag-lens   { fill: #ffffff; fill-opacity: 0.22; stroke: #3f3f3f; stroke-width: 3; }
  .kd-mag-handle { stroke: #3f3f3f; stroke-width: 4; stroke-linecap: round; }

  .kd-keyrail  { stroke: var(--color-rule); stroke-width: 1.5; stroke-dasharray: 4 3; fill: none; }
  .kd-key-bow  { fill: none; stroke: #c08a17; stroke-width: 2.2; }
  .kd-key-stem { stroke: #c08a17; stroke-width: 2.2; }
  .kd-key-l    { fill: var(--color-text); font-size: 13px; font-weight: 700; text-anchor: middle; }
  .kd-prob-l   { fill: var(--color-text-mute); font-size: 13px; }

  .kd-up  { stroke: var(--color-rule); stroke-width: 1.6; fill: none; }
  .kd-bus { stroke: var(--color-rule); stroke-width: 1.6; }

  .kd-panel-bg  { fill: var(--card-bg); stroke: var(--card-border); stroke-width: 1; }
  .kd-p-kicker  { font-size: 11px; font-weight: 700; letter-spacing: 0.6px; }
  .kd-p-title   { fill: var(--color-text); font-size: 16px; font-weight: 700; }
  .kd-rule      { stroke: var(--color-rule); stroke-width: 1; }
  .kd-p-body    { fill: var(--color-text-mute); font-size: 12px; }
  .kd-p-tag     { fill: var(--color-text); font-size: 11.5px; font-weight: 700; }
  .kd-p-status  { fill: var(--color-text); font-size: 12px; font-weight: 600; }
  .kd-panel--warn .kd-panel-bar, .kd-panel--warn .kd-p-kicker { fill: #c46a2a; }
  .kd-panel--acc  .kd-panel-bar, .kd-panel--acc  .kd-p-kicker { fill: var(--color-accent); }
  .kd-panel--q    .kd-panel-bar, .kd-panel--q    .kd-p-kicker { fill: #1a4a99; }

  .kd-lock-body    { fill: var(--color-bg); stroke: var(--color-text); stroke-width: 1.6; }
  .kd-lock-shackle { fill: none; stroke: var(--color-text); stroke-width: 1.6; }
  .kd-lock-hole    { fill: var(--color-text); stroke: none; }
  .kd-chip       { stroke: none; }
  .kd-chip--x    { fill: #c46a2a; }
  .kd-chip--v    { fill: #2e8b6b; }
  .kd-chip-mark  { stroke: #fff; stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; }

  .zfig :global(figcaption) {
    margin: var(--space-2) 0 0; font-size: var(--text-sm);
    line-height: var(--leading-snug); color: var(--color-text-mute);
  }
  .zfig :global(figcaption) strong { color: var(--color-text); }

  @media (max-width: 34rem) { .kd-h-title { font-size: 13px; } .zfig__phase { font-size: var(--text-xs); } }

  :global(.kd-fullscreen) {
    position: fixed; inset: 0; margin: auto;
    width: min(96vw, 1500px); max-width: 96vw; max-height: 94vh;
    padding: 0; border: 1px solid var(--card-border); border-radius: var(--radius);
    background: var(--card-bg); color: var(--color-text); overflow: auto;
  }
  :global(.kd-fullscreen)::backdrop { background: rgba(0, 0, 0, 0.55); }
  :global(.kd-fullscreen) .zfig { border: none; background: transparent; }
</style>
