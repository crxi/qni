---
import type { Annotation } from "../lib/data";

interface Props { annotation: Annotation; }
const { annotation } = Astro.props;
---

<aside class="annotation-callout" style={`--ann-color: ${annotation.color};`}>
  <h4>{annotation.label}</h4>
  <p>{annotation.sublabel}</p>
</aside>

<style>
  .annotation-callout {
    border-inline-start: 3px solid var(--ann-color);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    box-shadow: var(--shadow-sm);
    break-inside: avoid;
  }
  .annotation-callout h4 {
    margin: 0 0 var(--space-1);
    font-size: var(--text-base);
    color: var(--ann-color);
  }
  .annotation-callout p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-mute);
    line-height: var(--leading-snug);
  }
</style>
