---
import type { PlatformBase } from "../lib/data";
import { platformVendorList, data } from "../lib/data";

interface Props { platform: PlatformBase; }
const { platform } = Astro.props;
const vendors = platformVendorList(platform);
const flagship = data.flagship_machines[platform.id];
const kindLabel = platform.kind === "memory" ? "Memory" : platform.kind === "source" ? "Source" : "Computer";

/**
 * Convert *asterisk-bold* markdown fragments to <strong class="future"> spans.
 * Matches render.py's text_with_bold() so future/planned machines show up
 * the same way in both pipelines.
 */
function renderFlagship(s: string): string {
  return s.replace(/\*([^*]+)\*/g, '<strong class="future">$1</strong>');
}
---

<article
  class="platform-card"
  id={`platform-${platform.id}`}
  data-kind={platform.kind ?? "computer"}
  data-platform-card-id={platform.id}
  tabindex="-1"
  style={`--platform-color: ${platform.color};`}
>
  <header class="platform-card__head">
    <div class="platform-card__rule"></div>
    <div class="platform-card__body">
      <div class="platform-card__title">
        <h3>{platform.label}</h3>
        <span class="platform-card__kind">{kindLabel}</span>
      </div>
      {platform.subtitle && <p class="platform-card__subtitle">{platform.subtitle}</p>}
    </div>
  </header>

  {flagship && (
    <p class="platform-card__field">
      <span class="platform-card__field-label">Flagship machines</span>
      <span set:html={renderFlagship(flagship)} />
    </p>
  )}

  {vendors.length > 0 && !flagship && (
    <p class="platform-card__field">
      <span class="platform-card__field-label">Vendors</span>
      <span>{vendors.join(" · ")}</span>
    </p>
  )}
</article>

<style>
  .platform-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    break-inside: avoid;
  }
  .platform-card[data-kind="memory"],
  .platform-card[data-kind="source"] {
    border-style: dashed;
  }
  .platform-card.flash {
    animation: card-flash 1.2s ease-out;
  }
  @keyframes card-flash {
    0%   { box-shadow: 0 0 0 3px var(--color-accent), var(--shadow-sm); }
    100% { box-shadow: var(--shadow-sm); }
  }
  .platform-card:hover {
    border-color: var(--platform-color, var(--color-accent));
  }
  /* The card head sets --platform-color via inline style; lift it to the card scope so the hover rule above can use it. */

  .platform-card__head {
    display: grid;
    grid-template-columns: var(--card-rule-width) 1fr;
    gap: var(--space-3);
    align-items: stretch;
  }
  .platform-card__rule {
    background: var(--platform-color);
    border-radius: 2px;
    min-height: 36px;
  }
  .platform-card__body { display: grid; gap: var(--space-1); }
  .platform-card__title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
  }
  .platform-card__title h3 {
    margin: 0;
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }
  .platform-card__kind {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--platform-color);
    font-weight: 600;
  }
  .platform-card__subtitle {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-mute);
  }
  .platform-card__field {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text);
  }
  .platform-card__field-label {
    display: block;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-mute);
    margin-block-end: var(--space-1);
  }
  .platform-card :global(.future) {
    font-weight: 700;
    color: var(--platform-color);
  }
</style>
