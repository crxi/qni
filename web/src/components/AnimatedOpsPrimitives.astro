---
/**
 * AnimatedOpsPrimitives — ops-primitives diagram, inlined and animated.
 *
 * Single source of truth: the SVG generated by
 * `scripts/diagrams/entanglement_ops.py`. The Python script tags each
 * row with `data-op-row`, each before/after panel with `data-op-side`,
 * and every named element with `data-name`. The static PNG export
 * (playwright → 2K) ignores the data-attributes, so the download path
 * stays identical to the static figure.
 *
 * Each row registers a `tick(beat)` handler that snaps its named
 * elements to that beat's pose (transform, opacity, filter). CSS
 * transitions handle the in-betweens, so reversing through beats
 * animates the action backward without any per-step inverse logic.
 * Adding a new row in Python adds a new `data-op-row="…"` group; if
 * no entry exists in the JS choreography table the row falls back to
 * the generic "after-side fades in on the final beats" behaviour.
 */
import fs from "node:fs";
import path from "node:path";
import { url } from "../lib/url.ts";

interface Props {
  src: string;
  alt: string;
  credit?: string;
  downloadHref?: string;
  downloadName?: string;
}

const { src, alt, credit, downloadHref, downloadName } = Astro.props as Props;

const svgPath = path.join(process.cwd(), "public", src.replace(/^\//, ""));
let svgRaw = "";
try {
  svgRaw = fs.readFileSync(svgPath, "utf8");
  svgRaw = svgRaw.replace(/<\?xml[^>]*\?>/, "").trim();
  svgRaw = svgRaw.replace(
    /<svg\b/,
    `<svg data-ops-primitives role="img" aria-label="${alt.replace(/"/g, "&quot;")}"`,
  );
} catch (e) {
  console.warn(`AnimatedOpsPrimitives: could not inline ${svgPath}: ${e}`);
}

const dlHref = downloadHref || src.replace(/\.svg(\?|#|$)/, "_2k.png$1");
const dlName = downloadName || dlHref.split("/").pop() || "figure.png";
const dlHrefAbs = dlHref.startsWith("/") ? url(dlHref) : dlHref;
---

<figure class="zfig" data-ops-figure>
  <div class="zfig__toolbar">
    <div class="zfig__playback" role="group" aria-label="Animation playback controls">
      {/* Inline SVG icons — Unicode playback glyphs (⏮ ⏸ ⏭ ▶) render
          as colourful Apple/Google emoji on phones regardless of the
          U+FE0E text-variation selector, so we use monochrome SVG
          paths drawn in currentColor instead. */}
      <button class="zfig__btn" type="button" data-ops-back aria-label="Step back" title="Step back">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M6 5v14h2V5zM20 5L9 12l11 7z" fill="currentColor"/>
        </svg>
      </button>
      <button class="zfig__btn" type="button" data-ops-play aria-label="Pause" title="Play / pause">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" data-icon-pause>
          <path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor"/>
        </svg>
      </button>
      <button class="zfig__btn" type="button" data-ops-fwd aria-label="Step forward" title="Step forward">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path d="M16 5v14h2V5zM4 5v14l11-7z" fill="currentColor"/>
        </svg>
      </button>
      <button class="zfig__btn zfig__btn--speed" type="button" data-ops-speed aria-label="Playback speed" title="Playback speed">1×</button>
    </div>
    <a
      class="zfig__btn"
      href={dlHrefAbs}
      download={dlName}
      aria-label="Download this figure as PNG"
      title="Download PNG (2K)"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <button
      class="zfig__btn"
      type="button"
      data-ops-fullscreen
      aria-label="View this animation full-screen"
      title="Full screen"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <path d="M4 10V4h6M20 10V4h-6M4 14v6h6M20 14v6h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  <div class="zfig__img-wrap" set:html={svgRaw}></div>
  {credit && <p class="zfig__credit">{credit}</p>}
  <slot />
</figure>

<script is:inline>
(function () {
  function initFigure(fig) {
    var svg = fig.querySelector("svg[data-ops-primitives]");
    if (!svg) return null;

  // 12-beat cycle: 0–5 success, 6–11 failure (HEG and HEP herald, so
  // they fail some of the time; we show both outcomes so the reader
  // sees the conditional nature of the protocols). The other rows run
  // beat % 6 — i.e. two laps of their own simple animation per cycle.
  //
  // Sub-beat semantics (success half; failure half maps the same way
  // but suppresses the herald + classical-bit transit + right-panel bond):
  //   sub 0: initial state
  //   sub 1: action begins  (photon flight / CNOT draw / meter approach)
  //   sub 2: measurement fires (BSA glow / flash / meter peak)
  //   sub 3: classical bits travel along the classical channel; meter
  //          glow settles to a residual hint
  //   sub 4: AFTER panel fades in — bits have arrived, the post-state
  //          (herald, purified pair, swapped bond, moved data qubit)
  //          appears
  //   sub 5: pause
  var TOTAL_BEATS = 12;
  var BEAT_MS = 900;             // wall-clock between automatic beats
  var PAUSE_AT_END_MS = 1300;    // extra hold before looping
  var rm = window.matchMedia("(prefers-reduced-motion: reduce)");

  // ── Helpers ────────────────────────────────────────────────────────────
  function $(sel, root) { return (root || svg).querySelector(sel); }
  function $$(sel, root) { return Array.prototype.slice.call((root || svg).querySelectorAll(sel)); }
  function byName(name, root) { return $('[data-name="' + name + '"]', root); }
  var SVG_NS = "http://www.w3.org/2000/svg";

  // Classical-bit glyph — a small dark square that travels along a
  // 3-stage polyline path via chained CSS-transform tweens:
  //   1. DROP   — from the source device (BSA / BSM meter / node) DOWN
  //               to the classical channel at lineY.
  //   2. SLIDE  — horizontally along the channel from x0 to x1.
  //   3. RISE   — UP the destination's vertical stub into its box.
  // Each stage is optional: pass `sourceTopY` to include the drop;
  // pass `destTopY` to include the rise. Same recipe as the swapping
  // page 1G figure's polyline classical bits.
  function mkBitSquare(parent, x0, x1, lineY, sourceTopY, destTopY) {
    var size = 6;
    var startY = sourceTopY != null ? sourceTopY : lineY;
    var endY   = destTopY   != null ? destTopY   : lineY;
    var rect = document.createElementNS(SVG_NS, "rect");
    rect.setAttribute("x", String(x0 - size / 2));
    rect.setAttribute("y", String(startY - size / 2));
    rect.setAttribute("width", String(size));
    rect.setAttribute("height", String(size));
    rect.setAttribute("fill", "#1f2937");
    rect.setAttribute("rx", "1");
    rect.setAttribute("opacity", "0");
    parent.appendChild(rect);
    return {
      el: rect,
      hasDrop: Math.abs(lineY - startY) > 0.5,
      hasRise: Math.abs(endY - lineY)   > 0.5,
      dropDy:  lineY - startY,                // 0 → drop-end
      slideDx: x1 - x0,                       // x at drop-end → x at slide-end
      slideDy: lineY - startY,                // y stays at line through slide
      riseDx:  x1 - x0,                       // x stays at destination through rise
      riseDy:  endY - startY,                 // final dy after rise
      timers: [],
    };
  }
  function setBit(bit, active) {
    if (!bit) return;
    bit.timers.forEach(clearTimeout);
    bit.timers.length = 0;
    if (active) {
      bit.el.style.opacity = "1";
      var T_DROP  = bit.hasDrop ? 180 : 0;
      var T_SLIDE = (bit.hasDrop || bit.hasRise) ? 600 : 750;
      // Stage 1 — drop from device into the classical line (if any).
      if (bit.hasDrop) {
        bit.el.style.transition = "transform 180ms ease-in, opacity 240ms ease";
        bit.el.style.transform = "translate(0," + bit.dropDy + "px)";
      }
      // Stage 2 — slide horizontally along the classical line.
      var fireSlide = function () {
        bit.el.style.transition = "transform " + T_SLIDE + "ms linear, opacity 240ms ease";
        bit.el.style.transform =
          "translate(" + bit.slideDx + "px," + bit.slideDy + "px)";
      };
      if (T_DROP > 0) bit.timers.push(setTimeout(fireSlide, T_DROP));
      else fireSlide();
      // Stage 3 — rise into the destination box (if any).
      if (bit.hasRise) {
        bit.timers.push(setTimeout(function () {
          bit.el.style.transition = "transform 180ms ease-out, opacity 240ms ease";
          bit.el.style.transform =
            "translate(" + bit.riseDx + "px," + bit.riseDy + "px)";
        }, T_DROP + T_SLIDE));
      }
    } else {
      // Fade in place — don't translate back to start, or the bit
      // would "bounce" backwards during the fade-out.
      bit.el.style.opacity = "0";
    }
  }
  // Silently re-arm a bit at its origin (transform reset with no
  // transition). Called one beat BEFORE the travel beat so the next
  // forward sweep starts cleanly from the origin without animating
  // back from the previous cycle's landing point.
  function primeBit(bit) {
    if (!bit) return;
    bit.timers.forEach(clearTimeout);
    bit.timers.length = 0;
    bit.el.style.transition = "none";
    bit.el.style.transform = "translate(0,0)";
    void bit.el.getBoundingClientRect();
  }
  // Shared amber drop-shadow recipe for measurement glows. Used on BSA
  // (HEG) and matter-side BSM meter (swapping, teleportation) so the
  // measurement-firing visual reads the same family across rows.
  function meterFilter(sub) {
    if (sub === 1) return "drop-shadow(0 0 4px #fbbf24)";
    if (sub === 2) return "drop-shadow(0 0 8px #f59e0b) drop-shadow(0 0 4px #fbbf24)";
    if (sub === 3) return "drop-shadow(0 0 5px #fbbf24)";
    if (sub >= 4) return "drop-shadow(0 0 3px rgba(251, 191, 36, 0.4))";
    return "none";
  }
  // Red variant — HEP failure (measurement always fires; a mismatched
  // outcome forces the pair to be discarded).
  function meterFilterRed(sub) {
    if (sub === 1) return "drop-shadow(0 0 4px #fca5a5)";
    if (sub === 2) return "drop-shadow(0 0 8px #dc2626) drop-shadow(0 0 4px #fca5a5)";
    if (sub === 3) return "drop-shadow(0 0 5px #fca5a5)";
    if (sub >= 4) return "drop-shadow(0 0 3px rgba(220, 38, 38, 0.4))";
    return "none";
  }

  // Each row's `tick(beat)` handler. Falls back to generic if not listed.
  var choreography = {
    generation: hegChoreography(),
    purification: hepChoreography(),
    swapping: meterRowChoreography({
      meterName: "Swapping-bsm",
      // The relay's two memory qubits are the ones being measured by
      // the BSM. Glow them with the same amber filter so the reader
      // sees which qubits the meter is acting on.
      measuredNames: ["Swapping-MRL", "Swapping-MRR"],
      // Bits emit from the relay BSM and travel out to Bob.
      bitOrigin: function (row) {
        var m = byName("Swapping-bsm", row);
        return parseFloat(m.getAttribute("x")) + parseFloat(m.getAttribute("width")) / 2;
      },
      bitSourceTop: function (row) {
        var m = byName("Swapping-bsm", row);
        return parseFloat(m.getAttribute("y")) + parseFloat(m.getAttribute("height"));
      },
      bitTargets: function (row) {
        // Single right-bound bit — the Pauli correction message to
        // Bob is enough to illustrate "BSM → classical
        // communication". A symmetric left-bound bit would clutter
        // the picture without adding information.
        var nB = byName("Swapping-B", row);
        var line = byName("Swapping-classical-before", row);
        var bx = parseFloat(nB.getAttribute("x"));
        var bw = parseFloat(nB.getAttribute("width"));
        var by = parseFloat(nB.getAttribute("y"));
        var bh = parseFloat(nB.getAttribute("height"));
        return [{
          x: bx + bw / 2,
          y: parseFloat(line.getAttribute("y1")),
          yTop: by + bh,  // bit rises into B's box at end of slide
        }];
      },
      // The swapped-pair bond must not preview as a dim wavy line at
      // sub 0 — it should appear only once the BSM has fired and the
      // classical correction has reached both ends.
      afterOnlyNames: ["Swapping-bond"],
      // Both input Bell pairs AND the relay's two M qubits (circles +
      // text) are consumed by the BSM. Fading the bonds + the relay
      // qubits at sub ≥ 2 conveys "the relay is now empty" — which
      // matches the AFTER panel's empty-relay depiction.
      consumedNames: [
        "Swapping-AR", "Swapping-RB",
        "Swapping-MRL", "Swapping-MRL-in",
        "Swapping-MRR", "Swapping-MRR-in",
      ],
      rawBondName: "Swapping-bond-raw",
    }),
    teleportation: meterRowChoreography({
      meterName: "Teleportation-bsm",
      // Alice's two qubits — the data qubit D and her half of the
      // end-to-end Bell pair ML — are consumed by the matter-side BSM.
      // Glow both so the reader sees what gets measured.
      measuredNames: ["Teleportation-D", "Teleportation-ML"],
      // Alice (N0) sends 2 classical bits to Bob (N3). One emit point,
      // one landing point at Bob's node along the classical line.
      bitOrigin: function (row) {
        var m = byName("Teleportation-bsm", row);
        return parseFloat(m.getAttribute("x")) + parseFloat(m.getAttribute("width")) / 2;
      },
      bitSourceTop: function (row) {
        var m = byName("Teleportation-bsm", row);
        return parseFloat(m.getAttribute("y")) + parseFloat(m.getAttribute("height"));
      },
      bitTargets: function (row) {
        var nDest = byName("Teleportation-N3", row);
        var line = byName("Teleportation-classical-before", row);
        var dx = parseFloat(nDest.getAttribute("x"));
        var dw = parseFloat(nDest.getAttribute("width"));
        var dy = parseFloat(nDest.getAttribute("y"));
        var dh = parseFloat(nDest.getAttribute("height"));
        return [{
          x: dx + dw / 2,
          y: parseFloat(line.getAttribute("y1")),
          yTop: dy + dh,  // bit rises into Bob's box at end of slide
        }];
      },
      // Teleportation has no after-only element — the data qubit "D"
      // sits on the right panel from the start so it inherits the
      // panel's dim preview opacity, then brightens with the panel at
      // sub 4. That conveys "this is where D will land" throughout
      // the cycle instead of popping in unexpectedly at the end.
      afterOnlyNames: [],
      // Alice's BSM on (D, ML) destroys the M↔M entanglement entirely
      // — no raw Bell pair survives at MR (unlike swap). What's left is
      // a Pauli-rotated copy of D's state at MR, signalled by flipping
      // MR's label from "M" to "?" via the postBSM overlay below.
      // D and ML themselves are consumed (faded out at sub ≥ 2); their
      // information now lives in the classical bit travelling at sub 3.
      consumedNames: [
        "Teleportation-bond",
        "Teleportation-D", "Teleportation-Din",
        "Teleportation-ML", "Teleportation-ML-in",
        "Teleportation-MR-in",
      ],
      postBSMNames: ["Teleportation-MR-q"],
    }),
  };

  // ── Wavy path generator — ports `_bond_wave` from svglib.py so the
  // matter-photon bond can be re-drawn each frame as its end follows the
  // travelling photon. amp / halfWl match the Python defaults used for
  // HEG matter-photon bonds (`bond--matter-photon`, amp=4, half_wl=8).
  function wavyPath(x0, x1, y, amp, halfWl) {
    if (x1 <= x0 + 1) return "M " + x0 + " " + y + " L " + Math.max(x0, x1) + " " + y;
    var nHalf = Math.max(Math.floor((x1 - x0) / halfWl), 2);
    var span = nHalf * halfWl;
    var pad = (x1 - x0 - span) / 2;
    var sx = x0 + pad;
    var parts = ["M " + x0 + " " + y + " L " + sx + " " + y];
    parts.push("q " + (halfWl / 2) + " " + (-amp) + " " + halfWl + " 0");
    for (var i = 0; i < nHalf - 1; i++) parts.push("t " + halfWl + " 0");
    parts.push("L " + x1 + " " + y);
    return parts.join(" ");
  }

  // ── HEG choreography ───────────────────────────────────────────────────
  function hegChoreography() {
    var initialised = false;
    var phA, phB, bsa, afterPanel, beforePanel;
    var mpA, mpB;
    var bitR;
    var heraldOk, bondOk, heraldFail;
    var phAStartCx = 0, phAEndCx = 0;
    var phBStartCx = 0, phBEndCx = 0;
    // Matter-photon bond bounds: x0 stays at qubit edge, x1 follows photon.
    var mpA_x0 = 0, mpB_x0 = 0;
    var photonR = 8, cy = 0;
    var currentT = 0, frame = null;
    var prevBeat = 0;

    function init() {
      var row = svg.querySelector('[data-op-row="generation"]');
      if (!row) return false;
      beforePanel = row.querySelector('[data-op-side="before"]');
      afterPanel = row.querySelector('[data-op-side="after"]');
      phA = byName("HEG-phA", row);
      phB = byName("HEG-phB", row);
      mpA = byName("HEG-mp-A", row);
      mpB = byName("HEG-mp-B", row);
      bsa = byName("HEG-bsa-before", row);
      if (!phA || !phB || !mpA || !mpB || !bsa || !afterPanel || !beforePanel) return false;

      phAStartCx = parseFloat(phA.getAttribute("cx"));
      phBStartCx = parseFloat(phB.getAttribute("cx"));
      photonR = parseFloat(phA.getAttribute("r"));
      cy = parseFloat(phA.getAttribute("cy"));
      var bsaX = parseFloat(bsa.getAttribute("x"));
      var bsaW = parseFloat(bsa.getAttribute("width"));
      phAEndCx = bsaX;                          // photon centre lands at BSA left edge
      phBEndCx = bsaX + bsaW;                   // …and at BSA right edge
      mpA_x0 = phAStartCx - photonR - 4;        // small gap to the photon glyph (matches Python `phA_x - PHOTON_R`)
      mpB_x0 = phBStartCx + photonR + 4;

      // The Python emitter draws the bond from qubit-edge to (phA_x − PHOTON_R).
      // We use the bond's existing `d` to recover qubit-edge by parsing the M.
      var mpA_d0 = mpA.getAttribute("d") || "";
      var mA = mpA_d0.match(/^M\s+([\d.\-]+)/);
      if (mA) mpA_x0 = parseFloat(mA[1]);
      var mpB_d0 = mpB.getAttribute("d") || "";
      var mB = mpB_d0.match(/L\s+([\d.\-]+)\s+[\d.\-]+\s*$/);  // last L is the qubit-edge endpoint
      if (mB) mpB_x0 = parseFloat(mB[1]);

      // BSA glow uses a CSS drop-shadow filter on the <use> element
      // itself (same recipe as the meter rows). A square-ish glyph
      // wrapped in a round halo looked oversized; the fuzzy filter
      // hugs the shape and reads as the same family across all four
      // measurement primitives.
      bsa.style.transition = "filter 280ms ease";

      // Classical-bit square — a single herald glyph that travels from
      // the BSA to the right-hand node at sub 3. Showing only the
      // right-bound herald keeps the visual simple; the symmetric
      // left-bound message is implied.
      var nodeB = byName("HEG-B", row);
      var classLine = byName("HEG-classical-before", row);
      if (nodeB && classLine) {
        var bCx = parseFloat(nodeB.getAttribute("x")) + parseFloat(nodeB.getAttribute("width")) / 2;
        var classY = parseFloat(classLine.getAttribute("y1"));
        // Bit drops from BSA bottom, slides to B, rises into B's box.
        var bsaY  = parseFloat(bsa.getAttribute("y"));
        var bsaH  = parseFloat(bsa.getAttribute("height"));
        var bYTop = parseFloat(nodeB.getAttribute("y")) + parseFloat(nodeB.getAttribute("height"));
        bitR = mkBitSquare(beforePanel, bsaX + bsaW / 2, bCx, classY,
                            bsaY + bsaH, bYTop);
      }

      // Opacity transitions for fade-ins; transform is left to JS rAF.
      [phA, phB, mpA, mpB].forEach(function (el) {
        el.style.transition = "opacity 280ms ease";
      });
      afterPanel.style.transition = "opacity 700ms ease";

      // Success / failure overlay on the right panel. The static SVG
      // already carries the success-state ✓ herald + arched bond; we
      // inject a sibling "✗ heralded" label and toggle visibility per
      // beat.
      heraldOk = byName("HEG-herald", row);
      bondOk = byName("HEG-bond", row);
      if (heraldOk && bondOk) {
        [heraldOk, bondOk].forEach(function (el) {
          el.style.transition = "opacity 400ms ease";
        });
        heraldFail = document.createElementNS("http://www.w3.org/2000/svg", "text");
        heraldFail.setAttribute("x", heraldOk.getAttribute("x"));
        heraldFail.setAttribute("y", heraldOk.getAttribute("y"));
        heraldFail.setAttribute("class", "herald");
        heraldFail.setAttribute("text-anchor", "middle");
        heraldFail.setAttribute("font-size", "11");
        heraldFail.setAttribute("fill", "#b91c1c");
        heraldFail.setAttribute("opacity", "0");
        heraldFail.style.transition = "opacity 400ms ease";
        heraldFail.textContent = "✗ no herald";
        afterPanel.appendChild(heraldFail);
      }

      // Land at beat 0 visually so the inline SVG matches what the rAF
      // engine thinks is the current state.
      applyT(0);
      initialised = true;
      return true;
    }

    // Apply a tween position t in [0, 1]: 0 = beat 0 state (photon at
    // bond's far end), 1 = beat 1 state (photon at BSA's facing edge).
    function applyT(t) {
      // Photon translate so its centre lands on the interpolated x.
      var ax = phAStartCx + (phAEndCx - phAStartCx) * t;
      var bx = phBStartCx + (phBEndCx - phBStartCx) * t;
      phA.style.transform = "translate(" + (ax - phAStartCx) + "px,0px)";
      phB.style.transform = "translate(" + (bx - phBStartCx) + "px,0px)";
      // Bond stretches: x0 fixed at qubit edge; x1 follows photon's near edge.
      mpA.setAttribute("d", wavyPath(mpA_x0, ax - photonR, cy, 4, 8));
      mpB.setAttribute("d", wavyPath(bx + photonR, mpB_x0, cy, 4, 8));
    }

    function tweenTo(t1, dur) {
      if (frame) cancelAnimationFrame(frame);
      var t0 = currentT;
      var start = performance.now();
      function step() {
        var elapsed = performance.now() - start;
        var p = Math.min(1, elapsed / dur);
        // Ease in-out cubic for a smooth flight.
        var ease = p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2;
        currentT = t0 + (t1 - t0) * ease;
        applyT(currentT);
        if (p < 1) frame = requestAnimationFrame(step);
        else { currentT = t1; applyT(currentT); frame = null; }
      }
      frame = requestAnimationFrame(step);
    }

    function tick(beat) {
      if (!initialised && !init()) return;

      // 6-beat sub-cycle (success 0–5, failure 6–11). The left-side
      // action is identical in both halves; the difference is whether
      // the BSA fires at sub 2 and whether a herald + entangled pair
      // appears on the right at sub ≥ 4.
      var sub = beat % 6;
      var isFailure = beat >= 6;

      // Photon tween: animate forward only when entering sub 1 from sub 0
      // within the same half-cycle. All other transitions snap so loops
      // and reverse-stepping land cleanly.
      var newT = (sub >= 1) ? 1 : 0;
      var prevSub = prevBeat % 6;
      var goingForward01 = (prevBeat === beat - 1) && (prevSub === 0 && sub === 1);
      if (goingForward01) {
        tweenTo(newT, 850);
      } else {
        if (frame) { cancelAnimationFrame(frame); frame = null; }
        currentT = newT;
        applyT(newT);
      }

      // Photon + bond vanish once measured.
      var phOpacity = (sub >= 2) ? 0 : 1;
      var mpOpacity = (sub >= 2) ? 0 : 1;
      // BSA glow only in the success half. Reuses the shared meter
      // filter recipe so the visual matches the matter-side BSM rows.
      bsa.style.filter = isFailure ? "none" : meterFilter(sub);
      // AFTER panel sits at a dim preview until the bit has arrived;
      // then fades up to full opacity. The dim hint conveys
      // anticipation ("here's where the result lands"). Specific
      // outcome elements (herald label, bond) are toggled separately
      // below so they don't peek through during the preview.
      var afterOpacity = (sub >= 4) ? 1 : 0.15;

      phA.style.opacity = String(phOpacity);
      phB.style.opacity = String(phOpacity);
      mpA.style.opacity = String(mpOpacity);
      mpB.style.opacity = String(mpOpacity);
      afterPanel.style.opacity = String(afterOpacity);

      // Classical bits: travel out from BSA along the classical line
      // at sub 3, then disappear at sub 4 as the right panel takes
      // over. Suppressed entirely in the failure half (no herald → no
      // classical message).
      if (sub === 2 && !isFailure) primeBit(bitR);
      setBit(bitR, sub === 3 && !isFailure);

      // Right-panel success / failure variant — visible only once the
      // bit has arrived (sub ≥ 4).
      if (heraldOk && bondOk && heraldFail) {
        var showRight = sub >= 4;
        var failingNow = isFailure && showRight;
        heraldOk.style.opacity = String((!failingNow && showRight) ? 1 : 0);
        bondOk.style.opacity = String((!failingNow && showRight) ? 1 : 0);
        heraldFail.setAttribute("opacity", String(failingNow ? 1 : 0));
      }

      prevBeat = beat;
    }
    return tick;
  }

  // ── HEP choreography ───────────────────────────────────────────────────
  function hepChoreography() {
    var initialised = false;
    var beforePanel, afterPanel;
    var pair1, pair2, pairOut, fBefore, fAfter, heraldOk;
    var ma1, ma2, mb1, mb2;
    var ma2InLabel, mb2InLabel;
    var cnotG = null;
    var lineA, lineB, ctrlA, ctrlB, targA, targB;
    var labelA, labelB;
    var heraldFail;
    var bitAB, bitBA;

    function mkLine(x1, y1, x2, y2) {
      var l = document.createElementNS(SVG_NS, "line");
      l.setAttribute("x1", x1); l.setAttribute("y1", y1);
      l.setAttribute("x2", x2); l.setAttribute("y2", y2);
      l.setAttribute("stroke", "#1f2937");
      l.setAttribute("stroke-width", "1.4");
      return l;
    }
    function mkCircle(cx, cy, r, fill, stroke) {
      var c = document.createElementNS(SVG_NS, "circle");
      c.setAttribute("cx", cx); c.setAttribute("cy", cy); c.setAttribute("r", r);
      c.setAttribute("fill", fill); if (stroke) { c.setAttribute("stroke", stroke); c.setAttribute("stroke-width", "1.4"); }
      return c;
    }
    function mkTarget(cx, cy, r) {
      var g = document.createElementNS(SVG_NS, "g");
      g.appendChild(mkCircle(cx, cy, r, "#ffffff", "#1f2937"));
      // Plus sign inside the circle to mark the ⊕ target.
      var h = document.createElementNS(SVG_NS, "line");
      h.setAttribute("x1", cx - r); h.setAttribute("y1", cy);
      h.setAttribute("x2", cx + r); h.setAttribute("y2", cy);
      h.setAttribute("stroke", "#1f2937"); h.setAttribute("stroke-width", "1.2");
      g.appendChild(h);
      var v = document.createElementNS(SVG_NS, "line");
      v.setAttribute("x1", cx); v.setAttribute("y1", cy - r);
      v.setAttribute("x2", cx); v.setAttribute("y2", cy + r);
      v.setAttribute("stroke", "#1f2937"); v.setAttribute("stroke-width", "1.2");
      g.appendChild(v);
      return g;
    }

    function init() {
      var row = svg.querySelector('[data-op-row="purification"]');
      if (!row) return false;
      beforePanel = row.querySelector('[data-op-side="before"]');
      afterPanel = row.querySelector('[data-op-side="after"]');
      pair1 = byName("HEP-pair1", row);
      pair2 = byName("HEP-pair2", row);
      pairOut = byName("HEP-pair-out", row);
      fBefore = byName("HEP-F-before", row);
      ma1 = byName("HEP-MA1", row);
      ma2 = byName("HEP-MA2", row);
      mb1 = byName("HEP-MB1", row);
      mb2 = byName("HEP-MB2", row);
      if (!beforePanel || !afterPanel || !pair1 || !pair2 || !pairOut || !ma1 || !ma2 || !mb1 || !mb2) return false;

      // Inject CNOT decoration: vertical line + control dot + target ⊕,
      // one per side. Both start at opacity 0.
      var axA = parseFloat(ma1.getAttribute("cx"));
      var ayTop = parseFloat(ma1.getAttribute("cy"));
      var ayBot = parseFloat(ma2.getAttribute("cy"));
      var bxB = parseFloat(mb1.getAttribute("cx"));
      var qR = parseFloat(ma1.getAttribute("r"));
      cnotG = document.createElementNS(SVG_NS, "g");
      cnotG.setAttribute("opacity", "0");
      cnotG.style.transition = "opacity 280ms ease";
      lineA = mkLine(axA, ayTop + qR, axA, ayBot - qR);
      lineB = mkLine(bxB, ayTop + qR, bxB, ayBot - qR);
      ctrlA = mkCircle(axA, ayTop + qR + 5, 3.4, "#1f2937", null);
      ctrlB = mkCircle(bxB, ayTop + qR + 5, 3.4, "#1f2937", null);
      targA = mkTarget(axA, ayBot - qR - 6, 6);
      targB = mkTarget(bxB, ayBot - qR - 6, 6);
      [lineA, lineB, ctrlA, ctrlB, targA, targB].forEach(function (n) { cnotG.appendChild(n); });
      beforePanel.appendChild(cnotG);

      // Measurement glow on the target qubits themselves (no extra halo
      // circle) — uses the shared meterFilter recipe so HEP reads as the
      // same family as HEG's BSA glow and the matter-side BSM meter rows.
      // Failure half swaps amber for red to mark a discard.
      [ma2, mb2].forEach(function (el) {
        if (el) el.style.transition = "opacity 500ms ease, filter 280ms ease";
      });
      [pair2, fBefore].forEach(function (el) {
        if (el) el.style.transition = "opacity 500ms ease";
      });
      // MA2/MB2-in text labels — cached so per-tick fades don't re-query.
      ma2InLabel = byName("HEP-MA2-in", row);
      mb2InLabel = byName("HEP-MB2-in", row);
      [ma2InLabel, mb2InLabel].forEach(function (t) {
        if (t) t.style.transition = "opacity 500ms ease";
      });
      afterPanel.style.transition = "opacity 700ms ease";

      heraldOk = byName("HEP-herald", row);
      fAfter = byName("HEP-F-after", row);
      [heraldOk, fAfter, pairOut].forEach(function (el) {
        if (el) el.style.transition = "opacity 400ms ease";
      });
      heraldFail = document.createElementNS(SVG_NS, "text");
      if (heraldOk) {
        heraldFail.setAttribute("x", heraldOk.getAttribute("x"));
        heraldFail.setAttribute("y", heraldOk.getAttribute("y"));
      }
      heraldFail.setAttribute("text-anchor", "middle");
      heraldFail.setAttribute("font-size", "11");
      heraldFail.setAttribute("font-weight", "700");
      heraldFail.setAttribute("fill", "#b91c1c");
      heraldFail.setAttribute("opacity", "0");
      heraldFail.style.transition = "opacity 400ms ease";
      heraldFail.textContent = "✗ no herald";
      afterPanel.appendChild(heraldFail);

      // Measurement-outcome labels. Anchored outside the bottom qubits
      // (end-of-text left of MA2, start-of-text right of MB2) so they
      // sit clear of the classical line below and don't crowd the
      // panel border. "0,0" green on success; "0,1" red on failure.
      labelA = document.createElementNS(SVG_NS, "text");
      labelA.setAttribute("x", String(parseFloat(ma2.getAttribute("cx")) - qR - 2));
      labelA.setAttribute("y", String(parseFloat(ma2.getAttribute("cy")) + qR + 4));
      labelA.setAttribute("text-anchor", "end");
      labelA.setAttribute("font-size", "9");
      labelA.setAttribute("font-weight", "700");
      labelA.setAttribute("opacity", "0");
      labelA.style.transition = "opacity 240ms ease";
      beforePanel.appendChild(labelA);
      labelB = document.createElementNS(SVG_NS, "text");
      labelB.setAttribute("x", String(parseFloat(mb2.getAttribute("cx")) + qR + 2));
      labelB.setAttribute("y", String(parseFloat(mb2.getAttribute("cy")) + qR + 4));
      labelB.setAttribute("text-anchor", "start");
      labelB.setAttribute("font-size", "9");
      labelB.setAttribute("font-weight", "700");
      labelB.setAttribute("opacity", "0");
      labelB.style.transition = "opacity 240ms ease";
      beforePanel.appendChild(labelB);
      // Classical bits: each side sends its measurement outcome to the
      // other along the classical line under the qubits. Both bits
      // travel at sub 3; only success-half compares as "match".
      var nodeA_rect = byName("HEP-A", row);
      var nodeB_rect = byName("HEP-B", row);
      var hepClassLine = byName("HEP-classical-before", row);
      if (nodeA_rect && nodeB_rect && hepClassLine) {
        var aCx = parseFloat(nodeA_rect.getAttribute("x")) + parseFloat(nodeA_rect.getAttribute("width")) / 2;
        var bCx = parseFloat(nodeB_rect.getAttribute("x")) + parseFloat(nodeB_rect.getAttribute("width")) / 2;
        var classY = parseFloat(hepClassLine.getAttribute("y1"));
        var aYTop = parseFloat(nodeA_rect.getAttribute("y")) + parseFloat(nodeA_rect.getAttribute("height"));
        var bYTop = parseFloat(nodeB_rect.getAttribute("y")) + parseFloat(nodeB_rect.getAttribute("height"));
        // Each bit drops from its source node's bottom, slides to the
        // opposite node, and rises into its destination box.
        bitAB = mkBitSquare(beforePanel, aCx, bCx, classY, aYTop, bYTop);
        bitBA = mkBitSquare(beforePanel, bCx, aCx, classY, bYTop, aYTop);
      }

      // Pulse keyframes registered globally so we can toggle by class.
      if (!document.getElementById("ops-pulse-keyframes")) {
        var st = document.createElement("style");
        st.id = "ops-pulse-keyframes";
        st.textContent = "@keyframes hep-bond-pulse{0%,100%{stroke-width:2.5}50%{stroke-width:5}}" +
                         ".hep-pulsing{animation:hep-bond-pulse 1.6s ease-in-out infinite}";
        document.head.appendChild(st);
      }
      initialised = true;
      return true;
    }

    function tick(beat) {
      if (!initialised && !init()) return;

      // 12-beat cycle: sub-beat ∈ 0..5 within each half (success 0-5,
      // failure 6-11). The left-side action (CNOT draw + measurement)
      // is identical for both halves; the difference is whether the
      // measurement outcomes agree (success → kept) or mismatch
      // (failure → discarded).
      var sub = beat % 6;
      var isFailure = beat >= 6;

      var cnotOp = (sub === 1 || sub === 2) ? 1 : 0;
      // Measured qubits stay at full opacity through the firing beat so
      // the amber drop-shadow lights them up cleanly — matches the
      // swapping/teleportation rows. They drop out only at sub 3+ once
      // the measurement has consumed them.
      var fadingBottom = (sub >= 3) ? 0 : 1;
      var afterOp = (sub >= 4) ? 1 : 0.15;

      cnotG.setAttribute("opacity", String(cnotOp));
      // Drop-shadow glow on the two measured qubits only — amber on
      // success (matches HEG / meter rows), red on failure to mark the
      // discard. The CNOT decoration and the bottom pair don't glow;
      // they're not what's being measured.
      var glow = isFailure ? meterFilterRed(sub) : meterFilter(sub);
      if (ma2) ma2.style.filter = glow;
      if (mb2) mb2.style.filter = glow;

      [pair2, ma2, mb2, ma2InLabel, mb2InLabel].forEach(function (el) {
        if (el) el.style.opacity = String(fadingBottom);
      });
      if (fBefore) fBefore.style.opacity = String(sub >= 3 ? 0 : 1);
      afterPanel.style.opacity = String(afterOp);

      // Measurement-outcome labels: equal (0, 0) on success, mismatched
      // (0, 1) on failure. Only visible on the flash beat.
      var showLabels = (sub === 2) ? 1 : 0;
      if (showLabels) {
        labelA.textContent = "0";
        labelB.textContent = isFailure ? "1" : "0";
        var labelColour = isFailure ? "#b91c1c" : "#15803d";
        labelA.setAttribute("fill", labelColour);
        labelB.setAttribute("fill", labelColour);
      }
      labelA.setAttribute("opacity", String(showLabels));
      labelB.setAttribute("opacity", String(showLabels));

      // Classical bits travel at sub 3 in the success half; failure
      // half suppresses them (no herald → no kept pair, no message
      // needs to travel).
      // Bits always travel in HEP, success OR failure — that exchange
      // is how each side learns whether the outcomes matched and
      // decides keep / discard.
      if (sub === 2) { primeBit(bitAB); primeBit(bitBA); }
      setBit(bitAB, sub === 3);
      setBit(bitBA, sub === 3);

      // Right-panel success / failure variant — only after bits arrive.
      var showRight = sub >= 4;
      var failingNow = isFailure && showRight;
      if (heraldOk) heraldOk.style.opacity = String((!failingNow && showRight) ? 1 : 0);
      if (fAfter) fAfter.style.opacity = String((!failingNow && showRight) ? 1 : 0);
      if (pairOut) pairOut.style.opacity = String((!failingNow && showRight) ? 1 : 0);
      heraldFail.setAttribute("opacity", String(failingNow ? 1 : 0));

      // Pulsate the purified right-side bond only in the success half.
      if (showRight && !isFailure) pairOut.classList.add("hep-pulsing");
      else pairOut.classList.remove("hep-pulsing");
    }
    return tick;
  }

  // ── Meter-row choreography ─────────────────────────────────────────────
  // Shared timeline for the swapping + teleportation rows. Both rotate
  // around a rectangular BSM-meter glyph that "fires" in the middle of
  // the cycle. The meter glows amber via a CSS drop-shadow filter —
  // the fuzzy glow hugs the rectangular glyph (no extra halo circle).
  // The right-side post-state appears only after the meter fires and
  // the classical message has travelled.
  //
  // 6-beat sub-cycle (repeats twice per 12-beat round so these rows
  // stay in lockstep with HEG/HEP):
  //   sub 0: initial — meter at rest, after panel fully hidden.
  //   sub 1: meter haloed (soft amber glow).
  //   sub 2: meter peaks (intense amber glow) — BSM fires.
  //   sub 3: classical bits travel out from the meter; glow settles.
  //   sub 4: AFTER panel fades in (bond / moved data qubit appears).
  //   sub 5: pause.
  //
  // opts.meterName       – data-name of the BSM meter glyph in this row.
  // opts.bitOrigin       – function(row) → x-coord where bits emit.
  // opts.bitTargets      – function(row) → [{x, y}] landing points.
  // opts.afterOnlyNames  – data-names on the after side that must stay
  //                        hidden until sub ≥ 4 (so e.g. the swapped
  //                        bond doesn't peek as a dim line from start).
  // opts.consumedNames   – data-names on the before side that the BSM
  //                        consumes; fade to 0 at sub ≥ 2 alongside the
  //                        meter peak so the consumption beat is visible.
  // opts.rawBondName     – data-name of the post-BSM "raw" Bell pair —
  //                        entanglement that exists at sub 2 but isn't
  //                        yet in canonical form. Shown at sub 2–3,
  //                        hidden again at sub ≥ 4 when the canonical
  //                        AFTER bond takes over.
  // opts.postBSMNames    – data-names that fade IN at sub ≥ 2 (mirror of
  //                        consumedNames). Used for "?" overlay labels
  //                        signalling "state present but unresolved".
  function meterRowChoreography(opts) {
    var initialised = false;
    var afterPanel;
    var meterEl;
    var measuredEls = [];   // qubits being measured, glow alongside meter
    var bits = [];
    var afterOnlyEls = [];
    var consumedEls = [];   // input bonds the BSM consumes, fade at sub ≥ 2
    var rawBondEl = null;   // post-BSM raw Bell pair, visible at sub 2–3
    var postBSMEls = [];    // overlays that fade in at sub ≥ 2

    function init(row) {
      afterPanel = row.querySelector('[data-op-side="after"]');
      var beforePanel = row.querySelector('[data-op-side="before"]');
      meterEl = byName(opts.meterName, row);
      if (!afterPanel || !meterEl || !beforePanel) return false;
      meterEl.style.transition = "filter 280ms ease";
      afterPanel.style.transition = "opacity 700ms ease";

      if (opts.measuredNames) {
        opts.measuredNames.forEach(function (n) {
          var el = byName(n, row);
          if (el) {
            // Combined transition so the element can also live in
            // consumedNames without one entry clobbering the other.
            el.style.transition = "filter 280ms ease, opacity 280ms ease";
            measuredEls.push(el);
          }
        });
      }

      if (typeof opts.bitOrigin === "function" && typeof opts.bitTargets === "function") {
        var origin = opts.bitOrigin(row);
        // Optional: source device's bottom edge. When provided, the bit
        // starts there and drops DOWN onto the classical line before
        // sliding — i.e., the herald visibly emerges from the meter
        // rather than appearing on the line.
        var srcTop = typeof opts.bitSourceTop === "function"
          ? opts.bitSourceTop(row)
          : undefined;
        var targets = opts.bitTargets(row) || [];
        targets.forEach(function (t) {
          // t.yTop (optional) = destination box bottom; bit rises into it.
          bits.push(mkBitSquare(beforePanel, origin, t.x, t.y, srcTop, t.yTop));
        });
      }
      if (opts.afterOnlyNames) {
        opts.afterOnlyNames.forEach(function (n) {
          var el = byName(n, row);
          if (el) {
            el.style.transition = "opacity 500ms ease";
            afterOnlyEls.push(el);
          }
        });
      }
      if (opts.consumedNames) {
        opts.consumedNames.forEach(function (n) {
          var el = byName(n, row);
          if (el) {
            el.style.transition = "opacity 280ms ease";
            consumedEls.push(el);
          }
        });
      }
      if (opts.rawBondName) {
        var rb = byName(opts.rawBondName, row);
        if (rb) {
          rb.style.transition = "opacity 280ms ease";
          rawBondEl = rb;
        }
      }
      if (opts.postBSMNames) {
        opts.postBSMNames.forEach(function (n) {
          var el = byName(n, row);
          if (el) {
            el.style.transition = "opacity 280ms ease";
            postBSMEls.push(el);
          }
        });
      }
      initialised = true;
      return true;
    }

    return function (beat, row) {
      if (!initialised && !init(row)) return;
      var sub = beat % 6;
      var glow = meterFilter(sub);
      meterEl.style.filter = glow;
      measuredEls.forEach(function (el) { el.style.filter = glow; });
      if (sub === 2) bits.forEach(primeBit);
      bits.forEach(function (b) { setBit(b, sub === 3); });
      // Panel dimly previews the post-state for anticipation; specific
      // bond / data-qubit elements stay invisible until sub ≥ 4.
      afterPanel.style.opacity = sub >= 4 ? "1" : "0.15";
      afterOnlyEls.forEach(function (el) {
        el.style.opacity = sub >= 4 ? "1" : "0";
      });
      consumedEls.forEach(function (el) {
        el.style.opacity = sub >= 2 ? "0" : "1";
      });
      if (rawBondEl) {
        rawBondEl.style.opacity = (sub === 2 || sub === 3) ? "1" : "0";
      }
      postBSMEls.forEach(function (el) {
        el.style.opacity = sub >= 2 ? "1" : "0";
      });
    };
  }

  // ── Simple choreography for the other rows ─────────────────────────────
  // Left stays at full opacity throughout; right stays fully hidden until
  // sub ≥ 4 (no premature dim preview of the post-state).
  function simpleChoreography() {
    var initialised = false;
    var afterPanel;
    function init(row) {
      afterPanel = row.querySelector('[data-op-side="after"]');
      if (!afterPanel) return false;
      afterPanel.style.transition = "opacity 700ms ease";
      initialised = true;
      return true;
    }
    return function (beat, row) {
      if (!initialised && !init(row)) return;
      var sub = beat % 6;
      afterPanel.style.opacity = sub >= 4 ? "1" : "0.15";
    };
  }

  // ── Engine ─────────────────────────────────────────────────────────────
  var rows = $$("[data-op-row]");
  if (!rows.length) return;
  // Cache (row, tickFn) pairs in render order.
  var ticks = rows.map(function (r) {
    var fn = choreography[r.dataset.opRow] || simpleChoreography();
    return function (beat) { fn(beat, r); };
  });

  var beat = 0;
  var playing = false;
  var timer = null;
  // Playback speed multiplier — toolbar button cycles 0.5 → 0.75 → 1.
  // Scales the wall-clock interval between beats. Bit-transition CSS
  // durations stay fixed; at lower speeds the bit completes its slide
  // and waits before the next beat fires.
  var speed = 1.0;
  var SPEEDS = [0.5, 0.75, 1.0];

  function apply() { ticks.forEach(function (f) { f(beat); }); updatePlayButton(); }
  function step(d) {
    beat = Math.max(0, Math.min(TOTAL_BEATS - 1, beat + d));
    apply();
  }
  function reset() { beat = 0; apply(); }
  function pause() { playing = false; if (timer) clearTimeout(timer); timer = null; updatePlayButton(); }
  function play() {
    if (rm.matches) { beat = TOTAL_BEATS - 1; apply(); return; }
    playing = true;
    if (beat >= TOTAL_BEATS - 1) beat = 0;
    apply();
    schedule();
  }
  function schedule() {
    if (!playing) return;
    var atEnd = beat >= TOTAL_BEATS - 1;
    timer = setTimeout(function () {
      if (atEnd) { beat = 0; }
      else { beat += 1; }
      apply();
      schedule();
    }, (atEnd ? PAUSE_AT_END_MS : BEAT_MS) / speed);
  }
  function cycleSpeed() {
    var i = SPEEDS.indexOf(speed);
    speed = SPEEDS[(i + 1) % SPEEDS.length];
    var b = fig.querySelector("[data-ops-speed]");
    if (b) b.textContent = (speed === 1.0 ? "1×" : speed + "×");
    // If a beat is scheduled, reschedule so the change takes effect now.
    if (playing && timer) { clearTimeout(timer); schedule(); }
  }
  function updatePlayButton() {
    var b = fig.querySelector("[data-ops-play]");
    // Swap inline SVG icon — emoji fallbacks on Android render the
    // ⏸/▶ glyphs as colourful icons even with the text-variation
    // selector, so we paint monochrome SVG paths in currentColor.
    if (!b) return;
    b.setAttribute("aria-label", playing ? "Pause" : "Play");
    b.innerHTML = playing
      ? '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">'
        + '<path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor"/></svg>'
      : '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">'
        + '<path d="M7 4v16l13-8z" fill="currentColor"/></svg>';
  }

    fig.querySelector("[data-ops-back]").addEventListener("click", function () { pause(); step(-1); });
    fig.querySelector("[data-ops-fwd]").addEventListener("click", function () { pause(); step(+1); });
    fig.querySelector("[data-ops-play]").addEventListener("click", function () {
      if (playing) pause(); else play();
    });
    var btnSpeed = fig.querySelector("[data-ops-speed]");
    if (btnSpeed) btnSpeed.addEventListener("click", cycleSpeed);

    apply();
    if (!rm.matches) {
      // Tiny defer so the inline-SVG layout is settled before first animation.
      setTimeout(play, 80);
    } else {
      beat = TOTAL_BEATS - 1;
      apply();
    }

    return { teardown: pause };
  } // ── end initFigure ─────────────────────────────────────────────────────

  // Full-screen: clone the figure into a <dialog> and run the engine on
  // the clone so playback inside the modal is independent of the page
  // below. The clone's full-screen toolbar button is swapped for a
  // close button — keeps everything in one toolbar row, no overlay.
  function openFullScreen(srcFig) {
    var dialog = document.createElement("dialog");
    dialog.className = "ops-fullscreen";
    var clone = srcFig.cloneNode(true);
    delete clone.dataset.opsInited;
    var fsBtn = clone.querySelector("[data-ops-fullscreen]");
    if (fsBtn) {
      var close = document.createElement("button");
      close.type = "button";
      close.className = fsBtn.className;
      close.setAttribute("aria-label", "Close full-screen view");
      close.setAttribute("title", "Close");
      close.innerHTML = '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6 6l12 12M18 6l-12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';
      close.addEventListener("click", function () { dialog.close(); });
      fsBtn.parentNode.replaceChild(close, fsBtn);
    }
    dialog.appendChild(clone);
    document.body.appendChild(dialog);
    var handle = initFigure(clone);
    function destroy() {
      if (handle && handle.teardown) handle.teardown();
      dialog.remove();
    }
    dialog.addEventListener("close", destroy);
    dialog.addEventListener("click", function (e) {
      if (e.target === dialog) dialog.close();   // backdrop click
    });
    dialog.showModal();
  }

  document.querySelectorAll("[data-ops-figure]").forEach(function (fig) {
    if (fig.dataset.opsInited) return;
    fig.dataset.opsInited = "1";
    initFigure(fig);
  });

  document.addEventListener("click", function (e) {
    var t = e.target;
    var btn = t && t.closest && t.closest("[data-ops-fullscreen]");
    if (!btn) return;
    var fig = btn.closest("[data-ops-figure]");
    if (fig) openFullScreen(fig);
  });
})();
</script>

