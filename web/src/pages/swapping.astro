              `}</style>
              <marker id="g1-arr" viewBox="0 0 10 10" refX="8" refY="5"
                      markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#5a6472"/>
              </marker>
              <symbol id="g1-bsm-detector" overflow="visible">
                <path class="g1-bsm-det" d="M -14,0 A 14,14 0 0 1 14,0 Z"/>
              </symbol>
              {/* Real QuISP BSA glyph — same vector content as
                  icon-bsa-white.svg, identical to the one used in the
                  ops-primitives.svg on the home page. */}
              <symbol id="g1-bsa" viewBox="0 0 100 100" overflow="visible">
                <circle cx="50" cy="50" r="48.6" fill="#ffffff"/>
                <g transform="rotate(180 50 50)">
                  <g transform="translate(-31.460882,77.692164)">
                    <g transform="matrix(2.8375292,0,0,2.8375292,-4.7434798,-1217.7596)">
                      <circle fill="none" stroke="#1a1f2a" stroke-width="1" cx="30.380079" cy="419.40271" r="17.120964"/>
                      <rect fill="none" stroke="#1a1f2a" stroke-width="1" stroke-linejoin="round" width="11.686096" height="11.686096" x="-324.79691" y="-281.83298" transform="rotate(-135)"/>
