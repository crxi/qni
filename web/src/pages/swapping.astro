/**
 * /swapping — Entanglement swapping
 *
 * Tier A · Foundations.
 *
 * Citations:
 *   - zukowski-prl-1993 — Żukowski et al., PRL 71, 4287 (1993).
 *     The original entanglement-swapping proposal.
 *   - bennett-prl-1993 — teleportation; swapping is structurally
 *     "teleporting half of a Bell pair".
 *   - kumar-ijndc-2025 — current network survey.
 *   - jones-njp-2016 — repeater protocol architectures (MM/SR/MS),
 *     all built on swapping.
 *   - pompili-science-2021 — three-node experimental demo.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
