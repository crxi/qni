---
/**
 * /feedback — the site's contact channel.
 *
 * Feedback runs through GitHub issues; this page is a short pointer with a
 * button to the issue tracker. Kept off the landing page so the hero stays
 * about the subject, not about the site's plumbing.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
---

<Infographic
  title="Feedback"
  description="Report an error, share more current information, or suggest a concept worth animating."
>
  <SiteNav slot="nav" />

  <Center max="var(--content-width)" gutter="var(--space-3)">
    <Stack space="var(--space-5)">

      <header class="fb-hero">
        <h1>Feedback</h1>
        <p>
          Corrections, more current numbers, and ideas for concepts worth
          animating are all welcome. The more specific you can be — which
          page, which claim, what the right value is — the easier it is to
          act on.
        </p>
        <p>
          Feedback runs through GitHub issues, so there's one public place to
          see what's been raised and what's been fixed.
        </p>
      </header>

      <p class="fb-cta-row">
        <a
          class="fb-cta"
          href="https://github.com/crxi/qni/issues/new"
          target="_blank"
          rel="noopener"
        >Open an issue on GitHub →</a>
      </p>

    </Stack>
  </Center>
</Infographic>

<style>
  .fb-hero {
    padding-block: var(--space-6) var(--space-2);
    display: grid;
    gap: var(--space-3);
  }
  .fb-hero h1 {
    margin: 0;
    font-size: clamp(1.5rem, 5.5vw, 2.6rem);
    line-height: var(--leading-tight);
  }
  .fb-hero p {
    margin: 0;
    color: var(--color-text-mute);
  }
  .fb-cta-row { margin: 0; }
  .fb-cta {
    display: inline-block;
    font: inherit;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-bg);
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 10px 22px;
    text-decoration: none;
    transition: opacity 140ms ease;
  }
  .fb-cta:hover { opacity: 0.85; }
  .fb-cta:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
