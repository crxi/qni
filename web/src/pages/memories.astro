const sections = [
  { id: "overview",  label: "Overview" },
  { id: "metrics",   label: "What gets measured" },
  { id: "platforms", label: "Per-platform landscape" },
  { id: "spectrum",  label: "Where they sit on the spectrum" },
  { id: "trl",       label: "TRL benchmark" },
  { id: "role",      label: "Network role" },
];

/**
 * Per-platform comparison rows. Numbers are the best published
 * single-quantity demonstrations the cited surveys highlight, not
 * Pareto-optimal joint operating points: a memory that holds for an
 * hour is not the same memory that retrieves at 80 % efficiency.
 *
 * Sources for the storage-time and TRL columns:
 *   - meddeb-comnet-2025 Table 5 (six rows: atomic ensembles,
 *     solid-state, trapped ions, quantum dots, photonic,
 *     superconducting).
 *   - sangouard-rmp-83 for the DLCZ + RE-doped-crystal context that
 *     sits inside the "atomic ensembles" / "solid-state" rows.
 *   - knaut-nature-2024 for the nanophotonic SiV demonstration that
 *     anchors the solid-state defect row to a network deployment.
 *
 * Wavelength column is the optical interface most commonly used to
 * read/write the memory in current network-relevant experiments;
 * cross-referenced with the spectrum subject. Operating temperature
 * is the regime each platform currently runs in for memory work
 * (cold-atom MOTs at µK, RE-doped crystals in dilution / ³He
 * cryostats, NV/SiV at <100 mK for the cavity-coupled experiments,
 * quantum dots at ~4 K, photonic delay lines at room temperature).
 */
const platforms = [
  {
    id: "atomic-ensembles",
    label: "Atomic ensembles",
    sub: "Cold-atom DLCZ, EIT, AFC",
    storageTime: "≤ 1 hour (RE-doped, AFC)",
    storageNote: "Few ms in DLCZ-type demos; up to 1 h in atomic-frequency-comb storage.",
    multimode: "10s–100s of modes",
    temperature: "µK (cold atoms) · 2–4 K (RE-doped crystals)",
    interface: "Near-IR · 606 nm Pr:YSO · 580 nm Eu:YSO · 795/780 nm Rb/Cs",
    trl: "7–8",
    color: "var(--platform-atomic-ensemble, #4a8fbf)",
  },
  {
    id: "solid-state-defects",
    label: "Solid-state defects",
    sub: "NV centre, SiV centre in diamond",
    storageTime: "~100 µs (electron); seconds (nuclear)",
    storageNote: "Communication electron spin holds for ~100 µs; nearby ¹³C nuclear-spin register has been demonstrated past 1 s.",
    multimode: "1 (single emitter)",
    temperature: "< 100 mK (cavity-coupled SiV) · 4 K (NV)",
    interface: "637 nm (NV) · 737 nm (SiV); telecom via QFC",
    trl: "5–6",
    color: "var(--platform-defect, #b8675a)",
  },
  {
    id: "trapped-ions",
    label: "Trapped ions",
    sub: "Yb⁺, Ca⁺, Ba⁺, Sr⁺",
    storageTime: "~10 s (single-ion qubit memory)",
    storageNote: "Hyperfine-encoded qubits in a clock state. Hour-scale single-ion coherence has been reported at the qubit level; network-relevant memory experiments sit nearer the 10-s mark.",
    multimode: "1 per ion (per-ion register)",
    temperature: "Room-T trap, laser-cooled to mK",
    interface: "UV–visible (369 nm Yb⁺, 397 nm Ca⁺, 493 nm Ba⁺); telecom via QFC",
    trl: "6–7",
    color: "var(--platform-ion, #5a8a5a)",
  },
  {
    id: "neutral-atoms",
    label: "Neutral atoms",
    sub: "Optical-tweezer arrays, Rydberg",
    storageTime: "Seconds (clock-state nuclear-spin qubits)",
    storageNote: "Network-memory experiments in this platform are newer than the survey cycle; covered alongside atomic ensembles where the DLCZ-style read/write applies.",
    multimode: "Per-atom register; arrays of 100s of atoms",
    temperature: "µK (laser-cooled in optical tweezers)",
    interface: "Near-IR · 780 nm Rb · 852 nm Cs",
    trl: "—",
    color: "var(--platform-atom, #d4a44a)",
  },
  {
    id: "quantum-dots",
    label: "Semiconductor quantum dots",
    sub: "InAs/GaAs, hole-spin, charge-tunable",
    storageTime: "≤ 4 days (room-T charge memory demo)",
    storageNote: "The 4-day figure is a write-and-erase charge memory; network-relevant spin-photon memories in dots sit at ms–s.",
    multimode: "1 (single emitter)",
    temperature: "~4 K (network-grade); RT for charge-storage demo",
    interface: "900–1100 nm (InAs/GaAs); telecom via wavelength-tuned dots or QFC",
    trl: "5–6",
    color: "var(--platform-dot, #9e6ab8)",
  },
  {
    id: "photonic",
    label: "Photonic delay-line",
    sub: "Fibre loop, cavity, hollow-core",
    storageTime: "~2 µs (fibre-cavity telecom memory)",
    storageNote: "Storage at telecom wavelengths in single-mode fibre, no transduction needed. The cited number is short, and the platform inherits the link's own loss-per-km — every µs of storage is ~200 m of fibre.",
    multimode: "Time-bin · frequency · spatial multiplexing",
    temperature: "Room temperature (operates at the link's own temperature)",
    interface: "Telecom C-band (1530–1565 nm)",
    trl: "5–6",
    color: "var(--platform-photonic, #4f8a8a)",
  },
  {
    id: "superconducting",
    label: "Superconducting",
    sub: "Resonator-coupled qubit memory (RAQM)",
    storageTime: "~34 ms (single-photon resonator memory)",
    storageNote: "Random-Access Quantum Memory: a superconducting qubit is parked in a long-lived microwave resonator. Couples natively to superconducting processors but needs a microwave→optical transducer to sit on a fibre network.",
    multimode: "Few resonator modes",
    temperature: "10–20 mK (dilution refrigerator)",
    interface: "Microwave (5–10 GHz); telecom only via transduction",
