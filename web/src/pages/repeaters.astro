                <th>Error class</th>
                <th>1G</th>
                <th>2G</th>
                <th>3G</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">
                  Loss
                  <span class="rp-cell-sub">photon lost in fibre or missed at detector — heralded approaches retry until success</span>
                </th>
