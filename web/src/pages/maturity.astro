const sections = [
  { id: "overview",  label: "Overview" },
  { id: "qtrl",      label: "The QTRL framework" },
  { id: "platforms", label: "Per-platform memory TRLs" },
  { id: "capability", label: "Capability-aware ratings" },
  { id: "bottlenecks", label: "Where the bottlenecks are" },
