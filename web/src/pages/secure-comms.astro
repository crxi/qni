 *
 * Tier D · Applications. Split out of /applications so the
 * secure-communication line has room: symmetric encryption, the
 * key-distribution problem, the three ways to distribute a shared key
 * (classical public-key, post-quantum ML-KEM, QKD), and how QKD is
 * realised on the network.
 *
 * Citations:
 *   - bennett-brassard-1984 — BB84, the first QKD protocol.
 *   - wootters-nature-1982 — no-cloning, the physical basis of QKD security.
 *   - shor-siamjc-1997 — breaks RSA / ECDH.
 *   - nist-fips-203-2024 — ML-KEM (post-quantum KEM standard).
 *   - pirandola-aop-12-1012 — QKD advances / eavesdrop-detection security.
 *   - liu-prl-2023 — TF-QKD 1002 km fibre record.
 *   - islam-sciadv-2017 — high-dimensional QKD.
 *   - kumar-ijndc-2025 — quantum-internet application framing.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
