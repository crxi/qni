<script is:inline>
  // Sortable tables — click a <th data-sort="..."> to reorder rows.
  // Numeric columns parse the first floating-point number in the cell;
  // "—", "[unverified]", and blanks sort last in ascending order.
  (function () {
    function parseNumeric(s) {
      if (!s) return Number.POSITIVE_INFINITY;
      var m = s.replace(/,/g, "").match(/-?\d+(?:\.\d+)?(?:e-?\d+)?/i);
      return m ? parseFloat(m[0]) : Number.POSITIVE_INFINITY;
    }
    function cellSortKey(cell, type) {
      var raw = cell.getAttribute("data-sort-value");
      if (raw === null) raw = cell.textContent;
      raw = (raw || "").trim();
      if (type === "numeric") return parseNumeric(raw);
      return raw;
    }
    function sortTable(table, colIdx, type, asc) {
      var tbody = table.tBodies[0];
      var rows = Array.prototype.slice.call(tbody.rows);
      rows.sort(function (a, b) {
        var av = cellSortKey(a.cells[colIdx], type);
        var bv = cellSortKey(b.cells[colIdx], type);
        if (type === "numeric") {
          return asc ? av - bv : bv - av;
        }
        return asc ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
      });
      rows.forEach(function (r) { tbody.appendChild(r); });
    }
    document.querySelectorAll("table[data-sortable]").forEach(function (table) {
      var ths = table.tHead.rows[0].cells;
      Array.prototype.forEach.call(ths, function (th, idx) {
        var type = th.getAttribute("data-sort");
        if (!type) return;
        th.classList.add("sortable");
        th.addEventListener("click", function () {
          var asc = th.getAttribute("data-asc") !== "true";
          Array.prototype.forEach.call(ths, function (other) {
            other.removeAttribute("data-asc");
            other.classList.remove("sorted-asc", "sorted-desc");
          });
          th.setAttribute("data-asc", asc ? "true" : "false");
          th.classList.add(asc ? "sorted-asc" : "sorted-desc");
          sortTable(table, idx, type, asc);
        });
      });
    });
  })();
