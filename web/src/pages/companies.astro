---
/**
 * /companies — Vendor landscape (landing page)
 *
 * Tier E · Applications & market.
 *
 * The landing reads every YAML in qni/companies/ via the companies
 * loader and groups vendors by primary category. The textual platform
 * lists below (transmon / trapped-ion / etc.) survive as a static
 * snapshot for vendors that don't have a dossier yet — once a dossier
 * lands in qni/companies/<slug>.yaml, the vendor's name on this
 * landing page can be promoted to a link to its sub-page.
 *
 * Citations:
 *   - ezratty-uqt-2025-p2 — survey-level coverage of the vendor landscape.
 *   - meddeb-comnet-2025 — per-platform R&D status.
 *   - kumar-ijndc-2025 — survey-level positioning.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
import SourceNote from "../components/SourceNote.astro";
import CompanyLogo from "../components/CompanyLogo.astro";
import {
  COMPANIES,
  CATEGORY_LABEL,
  CATEGORY_ORDER,
  companiesByPrimary,
  type Company,
} from "../lib/companies.ts";
import { url } from "../lib/url";

const sections = [
  { id: "overview",   label: "Overview" },
  { id: "dossiers",   label: "Vendor dossiers" },
  { id: "systems",    label: "QC systems and roadmaps" },
  { id: "notes",      label: "Notes on this page" },
];

// Group dossiers by primary category, in the canonical CATEGORY_ORDER.
const grouped: { category: typeof CATEGORY_ORDER[number]; companies: Company[] }[] =
  CATEGORY_ORDER
    .map((c) => ({ category: c, companies: companiesByPrimary(c) }))
    .filter((g) => g.companies.length > 0);

const haveDossiers = COMPANIES.length > 0;

// Chip counts: how many dossiers carry each category in their `categories`
// list (not just as the primary one). A company tagged [memory, network]
// counts under both 'memory' and 'network', which matches the chip-filter
// semantics — clicking the chip should show every card with that category,
// not only those where it's primary.
const dossierCategoryCounts: Partial<Record<typeof CATEGORY_ORDER[number], number>> = {};
for (const c of COMPANIES) {
  for (const cat of c.categories) {
    dossierCategoryCounts[cat] = (dossierCategoryCounts[cat] ?? 0) + 1;
  }
}

// Country chips: extract the country (last comma-separated segment of `hq`)
// and count dossiers per country, normalising common aliases.
function extractCountry(hq: string | undefined | null): string {
  if (!hq) return "Unknown";
  const parts = hq.split(",").map((s) => s.trim()).filter(Boolean);
  if (parts.length === 0) return "Unknown";
  // Strip trailing parentheticals from the last segment — a dossier
  // like "Shanghai, China (China (Shanghai) Pilot Free Trade Zone)"
  // would otherwise land in a singleton bucket because the whole
  // parenthesised qualifier becomes the "country" string. Apply
  // before the alias lookup so the canonical form is what gets
  // normalised.
  let last = parts[parts.length - 1].replace(/\s*\(.*\)\s*$/, "").trim();
  // Normalise common variants.
  const aliases: Record<string, string> = {
    "US": "USA",
    "U.S.": "USA",
    "United States": "USA",
    "U.S.A.": "USA",
    "UK": "UK",
    "United Kingdom": "UK",
    "PRC": "China",
    "People's Republic of China": "China",
  };
  return aliases[last] ?? last;
}
// Per-company list of countries — primary HQ + every additional
// significant facility. A vendor with a manufacturing plant abroad
// (e.g., PsiQuantum's Brisbane fab) shows up under USA AND Australia.
function companyCountries(c: Company): string[] {
  const out = new Set<string>();
  out.add(extractCountry(c.hq));
  for (const loc of (c.additional_locations ?? [])) {
    out.add(extractCountry(loc));
  }
  return Array.from(out);
}

const countryCounts: Record<string, number> = {};
for (const c of COMPANIES) {
  for (const country of companyCountries(c)) {
    countryCounts[country] = (countryCounts[country] ?? 0) + 1;
  }
}
// Sort countries by count desc, then alphabetically for ties.
const COUNTRY_ORDER: string[] = Object.keys(countryCounts).sort((a, b) => {
  const d = (countryCounts[b] ?? 0) - (countryCounts[a] ?? 0);
  return d !== 0 ? d : a.localeCompare(b);
});

// Map country name → ISO 3166-1 alpha-2 code, used to pick the SVG flag in
// public/flags/<code>.svg. SVGs (not unicode flag emoji) so the flags render
// identically on every platform — Windows browsers don't support regional-
// indicator flag emoji and degrade them to the bare "CN" / "JP" code. Extend
// as new dossier HQs land; the helper falls back to a generic flag glyph.
const COUNTRY_ISO: Record<string, string> = {
  USA: "us",
  UK: "gb",
  "United Kingdom": "gb",
  Germany: "de",
  France: "fr",
  Netherlands: "nl",
  Switzerland: "ch",
  Canada: "ca",
  Japan: "jp",
  Singapore: "sg",
  Israel: "il",
  Luxembourg: "lu",
  China: "cn",
  Austria: "at",
  Finland: "fi",
  Australia: "au",
  Spain: "es",
  Denmark: "dk",
  Italy: "it",
  Sweden: "se",
  "South Korea": "kr",
  India: "in",
  Ireland: "ie",
};
const flagSrc = (c: string): string | null => {
  const iso = COUNTRY_ISO[c];
  return iso ? url(`/flags/${iso}.svg`) : null;
};
---

<Infographic
  title="Companies — vendor landscape"
  description="A growing index of vendors building quantum-network hardware and applications. Each tracked vendor has a deep-dive sub-page with milestones, roadmap, and capability metrics."
  references={[
    "ezratty-uqt-2025-p2",
    "kumar-ijndc-2025",
    "meddeb-comnet-2025",
  ]}
>
  <SiteNav slot="nav" currentSubject="companies" sections={sections} />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero" id="overview" data-nav-section>
        <h1>Companies — vendor landscape</h1>
        <p>
          A quantum-networking workspace that doesn't track vendors loses touch with what
          can actually be procured. This page has two layers: a deep-dive dossier per
          vendor — milestones, roadmap, capability metrics, all cited to primary sources
          — and a static landscape snapshot for vendors where the dossier hasn't been
          written yet <SourceNote id="ezratty-uqt-2025-p2" /><SourceNote id="meddeb-comnet-2025" />.
        </p>
        <p>
          Vendors split naturally into three buckets: <strong>computers</strong> (build
          quantum processors), <strong>networking &amp; QKD</strong> (build the network
          fabric or the QKD endpoints), and <strong>components</strong> (build the
          memories, sources, and other infrastructure that the other two consume).
        </p>
      </header>

      <section id="dossiers" data-nav-section>
        <h2>Vendor dossiers</h2>
        {haveDossiers ? (
          <p>
            Each dossier below links to a per-vendor page with milestones, roadmap, and
            modality-specific capability details. Compiled from primary sources (papers,
            vendor technology pages); see each page for source links. Use the search
            box and category chips to narrow the grid.
          </p>
        ) : (
          <p class="empty">No dossiers compiled yet.</p>
        )}

        {haveDossiers && (
          <div class="filter-bar" id="co-filter-bar">
            <div class="filter-top">
              <input type="search" id="co-search" placeholder="Search name, positioning, people, flagship, location…" class="co-search" />
              <button id="co-reset" class="co-reset" type="button">Reset</button>
            </div>
            <div class="filter-cols">
              <div class="filter-col">
                <span class="filter-row-label">Category</span>
                <div class="filter-chips" data-filter-group="category">
                  {CATEGORY_ORDER.filter((c) => (dossierCategoryCounts[c] ?? 0) > 0).map((c) => (
                    <button class={`chip cat-pill cat-${c}`} data-filter-value={c} aria-pressed="false" type="button">
                      {CATEGORY_LABEL[c]}
                      <span class="chip-count">{dossierCategoryCounts[c]}</span>
                    </button>
                  ))}
                </div>
              </div>
              <div class="filter-col">
                <span class="filter-row-label">Country</span>
                <div class="filter-chips" data-filter-group="country">
                  {COUNTRY_ORDER.map((country) => (
                    <button class="chip country-chip" data-filter-value={country} aria-pressed="false" type="button">
                      {flagSrc(country)
                        ? <img class="country-flag" src={flagSrc(country)} alt="" width="20" height="15" loading="lazy" decoding="async" />
                        : <span class="country-flag country-flag--none" aria-hidden="true">⚐</span>}
                      <span class="country-name">{country}</span>
                      <span class="chip-count">{countryCounts[country]}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          </div>
        )}

        <div id="co-dossiers">
          {grouped.map((group) => (
            <div class="dossier-group" data-group-cat={group.category}>
              <h3 class="dossier-group-title">{CATEGORY_LABEL[group.category]}</h3>
              <ul class="dossier-grid">
                {group.companies.map((c) => (
                  <li
                    class="dossier-card"
                    data-categories={c.categories.join(" ")}
                    data-country={companyCountries(c).join(" ")}
                    data-search={[
                      c.name,
                      c.positioning ?? "",
                      c.hq ?? "",
                      (c.additional_locations ?? []).join(" "),
                      c.categories.map((cc) => CATEGORY_LABEL[cc]).join(" "),
                      (c.key_personnel ?? []).map((p) => `${p.name} ${p.role}`).join(" "),
                      c.current_flagship ? `${c.current_flagship.name} ${c.current_flagship.generation ?? ""}` : "",
                    ].join(" ").toLowerCase()}
                  >
                    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/companies/${c.slug}`}>
                      <div class="dossier-head">
                        <div class="dossier-name">{c.name}</div>
                        <CompanyLogo name={c.name} slug={c.slug} height={24} />
                      </div>
                      <div class="dossier-positioning">{c.positioning}</div>
                      <div class="dossier-cats">
                        {c.categories.map((cc) => (
                          <span class={`cat-pill cat-${cc}`}>{CATEGORY_LABEL[cc]}</span>
                        ))}
                      </div>
                      <div class="dossier-meta">
                        <span class="dossier-hq">{c.hq}</span>
                        {(c.additional_locations ?? []).map((loc) => (
                          <span class="dossier-hq dossier-hq--alt">{loc}</span>
                        ))}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <p id="co-empty" class="co-empty" hidden>No dossiers match the current filters.</p>
      </section>

      <section id="systems" data-nav-section>
