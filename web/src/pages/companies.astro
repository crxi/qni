<script is:inline>
  (function () {
    const bar = document.getElementById("co-filter-bar");
    if (!bar) return;
    const search = /** @type {HTMLInputElement} */ (document.getElementById("co-search"));
    const reset  = document.getElementById("co-reset");
    const empty  = document.getElementById("co-empty");
    const catChips     = Array.from(bar.querySelectorAll('[data-filter-group="category"] .chip'));
    const countryChips = Array.from(bar.querySelectorAll('[data-filter-group="country"] .chip'));
    const cards  = Array.from(document.querySelectorAll("#co-dossiers .dossier-card"));
    const groups = Array.from(document.querySelectorAll("#co-dossiers .dossier-group"));

    const activeCats      = new Set();
    const activeCountries = new Set();
    let query = "";

    function apply() {
      let visibleTotal = 0;
      for (const card of cards) {
        const cats = (card.getAttribute("data-categories") || "").split(/\s+/).filter(Boolean);
        const countries = (card.getAttribute("data-country") || "").split(/\s+/).filter(Boolean);
        const searchText = card.getAttribute("data-search") || "";
        const matchesCat     = activeCats.size === 0      || cats.some((c) => activeCats.has(c));
        const matchesCountry = activeCountries.size === 0 || countries.some((c) => activeCountries.has(c));
        const matchesQuery   = query === ""               || searchText.indexOf(query) !== -1;
        const visible = matchesCat && matchesCountry && matchesQuery;
        card.hidden = !visible;
        if (visible) visibleTotal++;
      }
      // Hide whole group when all its cards are hidden.
      for (const group of groups) {
        const anyVisible = Array.from(group.querySelectorAll(".dossier-card"))
          .some((el) => !el.hidden);
        group.hidden = !anyVisible;
      }
      if (empty) empty.hidden = visibleTotal !== 0;
    }

    // Filter state is mirrored to the URL query string so it survives
    // navigation — clicking into a dossier and pressing Back restores the
    // same filters — and so a filtered view is shareable / bookmarkable.
    // replaceState (not push) keeps each keystroke/chip toggle out of the
    // history stack; the single /companies entry just carries the params.
    function syncURL() {
      const params = new URLSearchParams();
      if (activeCats.size)      params.set("cat", Array.from(activeCats).join(","));
      if (activeCountries.size) params.set("country", Array.from(activeCountries).join(","));
      const raw = search.value.trim();
      if (raw) params.set("q", raw);
      const qs = params.toString();
      history.replaceState(null, "", qs ? location.pathname + "?" + qs : location.pathname);
    }

    function readURL() {
      const params = new URLSearchParams(location.search);
      const cat = params.get("cat");
      const country = params.get("country");
      const q = params.get("q");
      if (cat)     for (const v of cat.split(","))     { if (v) activeCats.add(v); }
      if (country) for (const v of country.split(",")) { if (v) activeCountries.add(v); }
      if (q) { search.value = q; query = q.trim().toLowerCase(); }
      for (const c of catChips)
        c.setAttribute("aria-pressed", activeCats.has(c.getAttribute("data-filter-value")) ? "true" : "false");
      for (const c of countryChips)
        c.setAttribute("aria-pressed", activeCountries.has(c.getAttribute("data-filter-value")) ? "true" : "false");
    }

    function bindChipGroup(chips, activeSet) {
      for (const chip of chips) {
        chip.addEventListener("click", () => {
          const v = chip.getAttribute("data-filter-value");
          if (!v) return;
          if (activeSet.has(v)) {
            activeSet.delete(v);
            chip.setAttribute("aria-pressed", "false");
          } else {
            activeSet.add(v);
            chip.setAttribute("aria-pressed", "true");
          }
          apply();
          syncURL();
        });
      }
    }
    bindChipGroup(catChips,     activeCats);
    bindChipGroup(countryChips, activeCountries);

    search.addEventListener("input", () => {
      query = search.value.trim().toLowerCase();
      apply();
      syncURL();
    });

    reset?.addEventListener("click", () => {
      activeCats.clear();
      activeCountries.clear();
      query = "";
      search.value = "";
      for (const c of catChips)     c.setAttribute("aria-pressed", "false");
      for (const c of countryChips) c.setAttribute("aria-pressed", "false");
      apply();
      syncURL();
    });

    // Restore any filters encoded in the URL before the first render, so a
    // Back-navigation (or a shared link) lands on the filtered view.
    readURL();
    apply();
  })();
</script>

