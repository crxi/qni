/**
 * /case-studies/epb — EPB Quantum Network, Chattanooga.
 *
 * The first commercially-available quantum network in the US and one of the
 * very few entanglement-based networks open to outside customers under a paid
 * model. Differentiates from the Chinese QKD trunk (prepare-and-measure with
 * trusted relays) by distributing entangled photon pairs, which unlocks
 * protocols beyond QKD.
 */
import Infographic from "../../layouts/Infographic.astro";
import Center from "../../components/Center.astro";
import Stack from "../../components/Stack.astro";
import SiteNav from "../../components/SiteNav.astro";
