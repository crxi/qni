---
/**
 * /case-studies/micius — the Micius (Mozi) quantum-science satellite.
 *
 * Satellite-based quantum communication from LEO. The free-space channel
 * complement to the terrestrial fibre case studies.
 */
import Infographic from "../../layouts/Infographic.astro";
import Center from "../../components/Center.astro";
import Stack from "../../components/Stack.astro";
import SiteNav from "../../components/SiteNav.astro";
import SourceNote from "../../components/SourceNote.astro";
import { url } from "../../lib/url";

const sections = [
  { id: "overview",    label: "Overview" },
  { id: "what",        label: "What it is" },
  { id: "experiments", label: "Published experiments" },
  { id: "verified",    label: "Verified claims" },
  { id: "caveats",     label: "Things to note" },
  { id: "related",     label: "Related entries" },
];

// Landmark Micius results, chronological. `node` / `source` / `detector`
// record which device the security assumption rests on: "trusted" = the
// assumption is required, "untrusted" = the assumption is removed (the
// stronger position), "na" = not a key-distribution result for that device.
type Trust = "trusted" | "untrusted" | "na";
interface Experiment {
  year: string;
  name: string;
  ref: string;
  result: string;
  key: string;
  node: Trust;
  source: Trust;
  detector: Trust;
}
const experiments: Experiment[] = [
  {
    year: "2017", name: "Satellite-to-ground QKD", ref: "liao-nature-549",
    result: "Decoy-state BB84 downlink to Xinglong; ~300 kbit of sifted key over a 273 s pass, up to 1200 km.",
    key: "Yes", node: "trusted", source: "trusted", detector: "trusted",
  },
  {
    year: "2017", name: "Entanglement distribution", ref: "yin-science-2017",
    result: "Dual downlink to Delingha and Lijiang (~1203 km); entanglement survival certified by a Bell violation (S ≈ 2.37). Distribution only.",
    key: "No", node: "na", source: "untrusted", detector: "trusted",
  },
  {
    year: "2017", name: "Ground-to-satellite teleportation", ref: "ren-nature-2017",
    result: "Teleported single-photon qubits uplink to the satellite, up to ~1400 km, fidelity ~0.80 (above the classical bound).",
    key: "—", node: "na", source: "na", detector: "na",
  },
  {
    year: "2018", name: "Intercontinental network", ref: "liao-prl-2018",
    result: "Micius as a trusted relay across Xinglong, Nanshan and Graz; China–Austria keys over 7600 km, used for a Beijing–Vienna encrypted video call.",
    key: "Yes", node: "trusted", source: "trusted", detector: "trusted",
  },
  {
    year: "2019", name: "Gravitational-decoherence test", ref: "xu-science-2019",
    result: "Time-energy entangled pairs sent through Earth’s gravitational potential to test the “event formalism”; no decorrelation found, ruling the model out.",
    key: "—", node: "na", source: "na", detector: "na",
  },
  {
    year: "2020", name: "Entanglement-based QKD", ref: "yin-nature-2020",
    result: "BBM92 between Delingha and Nanshan; 0.12 bit/s finite-key secret rate, side-channel-hardened receivers.",
    key: "Yes", node: "na", source: "untrusted", detector: "trusted",
  },
  {
    year: "2020", name: "Quantum-secure time transfer", ref: "dai-natphys-2020",
    result: "Satellite-to-ground time transfer via two-way QKD; 30 ps precision, 9 kHz rate, QBER below 1%.",
    key: "—", node: "na", source: "trusted", detector: "trusted",
  },
  {
    year: "2021", name: "Integrated 4,600 km network", ref: "chen-natphoton-2021-jingu",
    result: "~700 fibre QKD links joined to two satellite-to-ground links; >150 users, 4600 km span, tens-of-kbps upgraded downlink.",
    key: "Yes", node: "trusted", source: "trusted", detector: "trusted",
  },
  {
    year: "2022", name: "Review", ref: "lu-rmp-2022",
    result: "Reviews the satellite-to-ground results — QKD, entanglement distribution, teleportation, and the fundamental-physics tests.",
    key: "—", node: "na", source: "na", detector: "na",
  },
];
const trustState: Record<Trust, string> = {
  trusted: "trusted — assumption required",
  untrusted: "untrusted — assumption removed",
  na: "not applicable",
};
const entityName: Record<string, string> = { N: "node", S: "source", D: "detector" };
---

<Infographic
  title="Micius (Mozi) satellite quantum-communication mission"
  description="The world's first quantum-science satellite: a low-Earth-orbit platform carrying an SPDC entangled-photon source, a decoy-state BB84 transmitter, and uplink-teleportation receivers. Distributed polarisation Bell pairs across a 1,200 km satellite-to-ground link (Yin et al., Science 356.1140, 2017) and a 1,120 km ground-station-to-ground-station link (Yin et al., Nature 582.501, 2020)."
  references={[
    "liao-nature-549",
    "yin-science-2017",
    "ren-nature-2017",
    "liao-prl-2018",
    "xu-science-2019",
    "yin-nature-2020",
    "dai-natphys-2020",
    "chen-natphoton-2021-jingu",
    "lu-rmp-2022",
  ]}
>
  <SiteNav slot="nav" currentSubject="case-studies" sections={sections} />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero" id="overview" data-nav-section>
        <h1>Micius (Mozi) satellite quantum-communication mission</h1>
        <p>
          The world's first quantum-science satellite. A Chinese Academy of
          Sciences platform in a ~500 km sun-synchronous low-Earth orbit,
          carrying an on-board entangled-photon source, a decoy-state BB84
          transmitter, and a single-photon receiver for uplink teleportation.
          The free-space optical complement to terrestrial fibre quantum
          networks — distances that fibre's 0.2 dB/km exponential loss makes
          unreachable without quantum repeaters.
        </p>
        <dl class="hero-meta">
          <div><dt>Operator</dt><dd>USTC / Pan Jianwei group · Chinese Academy of Sciences · National Space Science Center</dd></div>
          <div><dt>Location</dt><dd>~500 km sun-synchronous LEO; ground stations at Delingha, Lijiang, Nanshan, Xinglong (China) and Graz (Austria)</dd></div>
          <div><dt>Year</dt><dd>Launched 16 August 2016; first results 2017</dd></div>
          <div><dt>Technology</dt><dd>Entanglement-based (on-board SPDC type-II BBO source, polarisation-encoded ~810 nm); decoy-state BB84 downlink; uplink teleportation; free-space optical channels</dd></div>
          <div><dt>Scale</dt><dd>1,200 km satellite-to-ground; 1,120 km ground-station-to-ground-station via satellite; 4,600 km space-ground integrated when combined with the Beijing–Shanghai trunk</dd></div>
          <div><dt>Status</dt><dd>Operational mission</dd></div>
          <div><dt>Commercial model</dt><dd>National research mission — not a commercial service</dd></div>
        </dl>
      </header>

      <section id="what" data-nav-section>
        <h2>What it is</h2>
        <p>
          Micius carries three optical payloads. An SPDC source pumps a
          type-II BBO crystal to generate polarisation-entangled photon pairs
          at ~810 nm; two independent transmit telescopes downlink the two
          halves of each Bell pair to a pair of ground stations during a
          single overhead pass. A separate decoy-state BB84 transmitter sends
          weak coherent pulses for prepare-and-measure QKD. A receive
          telescope plus single-photon detectors close the loop for
          ground-to-satellite teleportation experiments. All three modes use
          the same fundamental channel — a free-space optical link through
          the atmosphere, with the satellite tracking the ground station for
          the duration of a usable pass.<SourceNote id="yin-science-2017" />
        </p>
        <p>
          The 2020 entanglement-based QKD result is the architecturally
          distinctive one. The satellite plays the role of a midpoint Bell
          pair source between two ground stations 1,120 km apart, and the
          security argument rests on the entanglement itself rather than on
          trust in the satellite. The 4,600 km figure, by contrast, is
          assembled by chaining the satellite with the Beijing–Shanghai fibre
          trunk under a trusted-node model — the satellite is one more
          trusted hop, not an entanglement source for the whole
          span.<SourceNote id="yin-nature-2020" />
        </p>
      </section>

      <section id="experiments" data-nav-section>
        <h2>Published experiments</h2>
        <p>
          The landmark results published from the mission, chronological.
          <strong>Secret key?</strong> marks whether the run produced shared
          key material rather than only moving or certifying quantum states.
          <strong>Trust</strong> breaks the security assumption down by the
          device it rests on — the relay <strong>node</strong>
          <span class="trust-chip trust-chip--trusted">N</span> that forwards a
          classical key, the <strong>source</strong>
          <span class="trust-chip trust-chip--trusted">S</span> that emits the
          quantum states, and the <strong>detector</strong>
          <span class="trust-chip trust-chip--trusted">D</span> that measures them.
          Entanglement-based QKD removes trust in the <em>source</em>;
          measurement-device-independent (MDI) QKD would remove trust in the
          <em>detector</em>, and device-independent (DI) QKD removes both. None
          of the Micius links are MDI or DI, so their receivers are always
          trusted.<SourceNote id="lu-rmp-2022" />
        </p>
        <div class="trust-legend">
          <span>
            <span class="trust-chip trust-chip--trusted">N</span>
            <span class="trust-chip trust-chip--trusted">S</span>
            <span class="trust-chip trust-chip--trusted">D</span>
            node / source / detector
          </span>
          <span><span class="trust-swatch trust-swatch--trusted"></span> filled = trusted (assumption required)</span>
          <span><span class="trust-swatch trust-swatch--untrusted"></span> outline = untrusted (assumption removed)</span>
          <span>only the devices a result involves are shown</span>
        </div>
        <div class="exp-table-wrap">
        <table class="exp-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Experiment</th>
              <th>Result</th>
              <th>Secret key?</th>
              <th>Trust</th>
            </tr>
          </thead>
          <tbody>
            {experiments.map((e) => {
              const chips: [string, Trust][] = [["N", e.node], ["S", e.source], ["D", e.detector]];
              const allNa = e.node === "na" && e.source === "na" && e.detector === "na";
              return (
                <tr>
                  <td>{e.year}</td>
                  <td>{e.name} <SourceNote id={e.ref} /></td>
                  <td>{e.result}</td>
                  <td>{e.key}</td>
                  <td>
                    {allNa ? (
                      <span class="trust-dash">—</span>
                    ) : (
                      <span class="trust-chips">
                        {chips.map(([letter, state]) => (
                          state !== "na" && (
                            <span class={`trust-chip trust-chip--${state}`} title={`${entityName[letter]}: ${trustState[state]}`}>{letter}</span>
                          )
                        ))}
                      </span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        </div>
        <p class="exp-note">
          Every QKD link here also rests on assumptions no Micius experiment
          relaxes: the endpoints' own apparatus (Alice's and Bob's secure labs),
          the random-number source that picks bases and states, and an
          authenticated classical channel. Those stay trusted throughout; the
          node / source / detector split is only the part that varies across
          the experiments.
        </p>
        <p class="exp-note">
          The Bell violation in the 2017 entanglement-distribution result is a
          one-time certification of the channel, not part of any key protocol.
          The 2020 BBM92 link runs no Bell test during operation — its security
          rests on the QBER staying below the secret-key threshold, with the
          entanglement removing the need to trust the source. The 2012
          (100 km free-space teleportation) and 2013 (ground feasibility)
          demonstrations predate the 2016 launch and were not flown on Micius;
          they are out of scope here.
        </p>
      </section>

      <section id="verified" data-nav-section>
        <h2>Verified claims</h2>
        <ul class="claim-list">
          <li><strong>1,200 km satellite-to-two-ground-station Bell pair distribution, Delingha and Lijiang</strong> — polarisation entanglement preserved through the dual downlink with a Bell-inequality violation of 2.37σ to 4σ.<SourceNote id="yin-science-2017" /></li>
          <li><strong>SPDC entangled-photon source on the satellite</strong> — type-II BBO crystal, ~810 nm, two independent transmit telescopes feeding the two ground stations.<SourceNote id="yin-science-2017" /></li>
          <li><strong>1,120 km entanglement-based QKD between Delingha and Nanshan</strong> — satellite as midpoint source; security argument independent of trust in the satellite.<SourceNote id="yin-nature-2020" /></li>
          <li><strong>Free-space optical channel, ~810 nm downlink</strong> — chosen for atmospheric transmission and detector quantum efficiency; not telecom-band.</li>
          <li><strong>Operational mission since 2016, multiple follow-up experiments published</strong> — including ground-to-satellite teleportation (Ren <em>et al.</em>, Nature 2017)<SourceNote id="ren-nature-2017" /> and the integrated 4,600 km space-ground demonstration.<SourceNote id="chen-natphoton-2021-jingu" /></li>
        </ul>
      </section>

      <section id="caveats" data-nav-section>
        <h2>Things to note</h2>
        <ul class="caveat-list">
          <li><strong>One satellite, one pass at a time.</strong> Useful link time per ground station is a few minutes per overhead pass; average key throughput over a day is bit/s to kbit/s class.</li>
          <li><strong>Operating conditions for the free-space downlink.</strong> The standard operating window is clear-sky night passes over the participating ground stations; daylight QKD has been demonstrated at lower rates.</li>
          <li><strong>The 4,600 km figure is trusted-node-assisted.</strong> It chains Micius with the Beijing–Shanghai fibre trunk, with the satellite acting as a trusted relay for the inter-segment hop. The trust model matches the terrestrial backbone rather than end-to-end entanglement.</li>
          <li><strong>The 2020 entanglement-based QKD removes the trusted-satellite assumption for the link layer at bit/s-class secure-key rates.</strong> The result establishes the architecture at demonstration scale.</li>
          <li><strong>Distinct system from the Beijing–Shanghai trunk.</strong> Micius is a separate physical platform with a separate vendor stack — see the <a href={url("/case-studies/china-backbone")}>china-backbone</a> entry for the terrestrial side.</li>
        </ul>
      </section>

      <section id="related" data-nav-section>
        <h2>Related entries</h2>
        <ul class="related-list">
          <li><a href={url("/distribution")}>Entanglement distribution</a> — free-space optical as a third channel alongside fibre and matter-qubit links.</li>
          <li><a href={url("/applications")}>Applications</a> — QKD as the primary use case for the Micius downlinks.</li>
          <li><a href={url("/links")}>Links</a> — the free-space loss budget that LEO downlinks have to close.</li>
          <li><a href={url("/case-studies/china-backbone")}>Beijing–Shanghai QKD backbone</a> — the terrestrial side of the integrated 4,600 km space-ground network.</li>
          <li><a href={url("/companies")}>Companies</a> — the Chinese vendor ecosystem (QuantumCTek and others) that supplies the ground-segment hardware.</li>
        </ul>
      </section>

    </Stack>
  </Center>
</Infographic>

<style>
  .hero { padding-block: var(--space-6) var(--space-4); border-block-end: 1px solid var(--color-rule); display: grid; gap: var(--space-3); }
  .hero h1 { margin: 0; }
  .hero-meta { display: grid; gap: var(--space-1); margin: 0; padding: var(--space-3); background: var(--color-surface-2); border-radius: var(--radius); font-size: var(--text-sm); }
  .hero-meta div { display: grid; grid-template-columns: 11rem 1fr; gap: var(--space-2); }
  .hero-meta dt { color: var(--color-text-mute); text-transform: uppercase; letter-spacing: var(--tracking-wide); font-size: var(--text-xs); font-weight: 600; align-self: center; }
  .hero-meta dd { margin: 0; color: var(--color-text); }
  @media (max-width: 40rem) { .hero-meta div { grid-template-columns: 1fr; gap: 0; } }
  .claim-list, .caveat-list, .related-list { display: grid; gap: var(--space-2); padding-inline-start: var(--space-4); }
  .claim-list li, .caveat-list li { line-height: var(--leading-body); }

  .exp-table-wrap {
    inline-size: 100%;
    overflow-x: auto;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--card-bg);
  }
  .exp-table {
    min-inline-size: 52rem;
    inline-size: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }
  .exp-table thead th {
    text-align: start;
    padding: var(--space-2) var(--space-3);
    border-block-end: 2px solid var(--color-rule);
    color: var(--color-text);
    font-weight: 600;
    background: var(--card-bg);
  }
  .exp-table tbody td {
    padding: var(--space-2) var(--space-3);
    vertical-align: top;
    border-block-end: 1px solid var(--color-rule);
    color: var(--color-text-mute);
  }
  .exp-table tbody td:nth-child(2) { color: var(--color-text); font-weight: 500; }
  .exp-table tbody tr:last-child td { border-block-end: 0; }
  .exp-note {
    font-size: var(--text-sm);
    color: var(--color-text-mute);
    line-height: var(--leading-snug);
    margin: 0;
  }

  /* Trust chips: which device the security assumption rests on.
     Filled photon-blue = trusted; photon-blue outline = untrusted, the stronger
     position (entanglement-based). Detector is never untrusted here — no MDI/DI. */
  .trust-chips { display: inline-flex; gap: 3px; }
  .trust-chip {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 1.5em; block-size: 1.5em;
    font-size: var(--text-xs); font-weight: 700; line-height: 1;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    vertical-align: middle;
    position: relative;
    top: -0.08em;
  }
  .trust-chip--trusted {
    background: #1a4a99;
    color: #fff;
    border-color: #1a4a99;
  }
  .trust-chip--untrusted {
    background: transparent;
    color: #1a4a99;
    border-color: #1a4a99;
    font-weight: 800;
  }
  .trust-dash { color: var(--color-text-soft); }
  .trust-legend {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: var(--space-1) var(--space-4);
    margin-block-start: var(--space-3);
    font-size: var(--text-xs); color: var(--color-text-mute);
  }
  .trust-legend > span { display: inline-flex; align-items: center; gap: 4px; }
  .trust-swatch {
    display: inline-block; inline-size: 0.85em; block-size: 0.85em;
    border-radius: 3px; border: 1px solid transparent; vertical-align: middle;
  }
  .trust-swatch--trusted { background: #1a4a99; border-color: #1a4a99; }
  .trust-swatch--untrusted { background: transparent; border-color: #1a4a99; }
</style>
