  .hero h1 { margin: 0; }
  .hero-meta { display: grid; gap: var(--space-1); margin: 0; padding: var(--space-3); background: var(--color-surface-2); border-radius: var(--radius); font-size: var(--text-sm); }
  .hero-meta div { display: grid; grid-template-columns: 11rem 1fr; gap: var(--space-2); }
  .hero-meta dt { color: var(--color-text-mute); text-transform: uppercase; letter-spacing: var(--tracking-wide); font-size: var(--text-xs); font-weight: 600; align-self: center; }
  .hero-meta dd { margin: 0; color: var(--color-text); }
  @media (max-width: 40rem) { .hero-meta div { grid-template-columns: 1fr; gap: 0; } }
  .claim-list, .caveat-list, .related-list { display: grid; gap: var(--space-2); padding-inline-start: var(--space-4); }
  .claim-list li, .caveat-list li { line-height: var(--leading-body); }

  /* Published-papers table — shared recipe with the Micius and Delft case studies. */
  .exp-table-wrap {
    inline-size: 100%;
    overflow-x: auto;
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    background: var(--card-bg);
  }
  .exp-table {
    min-inline-size: 52rem;
    inline-size: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }
  .exp-table thead th {
    text-align: start;
    padding: var(--space-2) var(--space-3);
    border-block-end: 2px solid var(--color-rule);
    color: var(--color-text);
    font-weight: 600;
    background: var(--card-bg);
  }
  .exp-table tbody td {
    padding: var(--space-2) var(--space-3);
    vertical-align: top;
    border-block-end: 1px solid var(--color-rule);
    color: var(--color-text-mute);
  }
  .exp-table tbody td:nth-child(2) { color: var(--color-text); font-weight: 500; }
  .exp-table tbody tr:last-child td { border-block-end: 0; }
</style>
