/**
 * /case-studies/qbird-rotterdam — Q*Bird's MDI-QKD hub-and-spoke pilot
 * in the Port of Rotterdam, announced 2024 with the QUEST follow-on
 * deployment running in 2025-26.
 */
import Infographic from "../../layouts/Infographic.astro";
import Center from "../../components/Center.astro";
import Stack from "../../components/Stack.astro";
