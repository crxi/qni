  .hero-meta { display: grid; gap: var(--space-1); margin: 0; padding: var(--space-3); background: var(--color-surface-2); border-radius: var(--radius); font-size: var(--text-sm); }
  .hero-meta div { display: grid; grid-template-columns: 11rem 1fr; gap: var(--space-2); }
  .hero-meta dt { color: var(--color-text-mute); text-transform: uppercase; letter-spacing: var(--tracking-wide); font-size: var(--text-xs); font-weight: 600; align-self: center; }
  .hero-meta dd { margin: 0; color: var(--color-text); }
  @media (max-width: 40rem) { .hero-meta div { grid-template-columns: 1fr; gap: 0; } }
  .claim-list, .caveat-list, .related-list { display: grid; gap: var(--space-2); padding-inline-start: var(--space-4); }
  .claim-list li, .caveat-list li { line-height: var(--leading-body); }
</style>
