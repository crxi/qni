/**
 * /case-studies/delft-three-node — QuTech / TU Delft three-node NV-centre
 * network. Pompili et al., Science 372.259 (2021); Hermans et al., Nature
 * 605.663 (2022) for the non-neighbour teleportation follow-up.
 */
import Infographic from "../../layouts/Infographic.astro";
import Center from "../../components/Center.astro";
import Stack from "../../components/Stack.astro";
import SiteNav from "../../components/SiteNav.astro";
import SourceNote from "../../components/SourceNote.astro";
import { url } from "../../lib/url";

const sections = [
  { id: "overview", label: "Overview" },
  { id: "what",     label: "What it is" },
  { id: "papers",   label: "Published papers" },
  { id: "verified", label: "Verified claims" },
  { id: "caveats",  label: "Things to note" },
  { id: "related",  label: "Related entries" },
];

// The Hanson-group lineage on one evolving platform, chronological. Each row
// removes a barrier the next result depends on.
const papers = [
  {
    year: "2015", ref: "hensen-nature-2015", paper: "Hensen et al., Nature 526.682",
    result: "Loophole-free Bell-inequality violation between two NV electron spins 1.3 km apart.",
    implies: "The nodes can be remotely entangled at all, with heralded success — the precondition for everything that follows.",
  },
  {
    year: "2018", ref: "humphreys-nature-2018", paper: "Humphreys et al., Nature 558.268",
    result: "Deterministic, on-demand delivery of remote entanglement between two nodes.",
    implies: "Entanglement arrives when the protocol asks for it, not only when a heralding click happens to land — fast enough to chain into a multi-node sequence.",
  },
  {
    year: "2021", ref: "pompili-science-2021", paper: "Pompili et al., Science 372.259",
    result: "Three-node network (Alice–Bob–Charlie); entanglement distribution plus a Bell-state measurement at Bob to swap.",
    implies: "The building blocks compose — a middle node links two others that never exchange a photon. First multinode entanglement-based network.",
  },
  {
    year: "2022", ref: "pompili-npjqi-2022", paper: "Pompili et al., npj QI 8.121",
    result: "Entanglement delivered through an explicit physical- and link-layer network stack.",
    implies: "The network runs on a layered protocol stack rather than bespoke lab control — the experimental counterpart to RFC 9340's link-layer service.",
  },
  {
    year: "2022", ref: "hermans-nature-2022", paper: "Hermans et al., Nature 605.663",
    result: "Deterministic qubit teleportation between the non-neighbouring nodes Alice and Charlie, via Bob.",
    implies: "The elementary quantum-internet primitive — moving an unknown qubit with a Bell pair and two classical bits — runs end-to-end on a real multi-node fabric.",
  },
];
---

<Infographic
  title="Delft three-node NV-centre network"
  description="The first multi-node entanglement-based network: three NV-centre quantum-memory nodes (Alice, Bob, Charlie) with entanglement distribution and entanglement swapping (Pompili et al., Science 372.259, 2021). A 2022 follow-up demonstrated qubit teleportation between non-neighbouring nodes."
  references={[
    "hensen-nature-2015",
    "humphreys-nature-2018",
    "pompili-science-2021",
    "pompili-npjqi-2022",
    "hermans-nature-2022",
  ]}
>
  <SiteNav slot="nav" currentSubject="case-studies" sections={sections} />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero" id="overview" data-nav-section>
        <h1>Delft three-node NV-centre network</h1>
        <p>
          The first multi-node entanglement-based quantum network: three
          nitrogen-vacancy (NV) memory nodes — Alice, Bob, and Charlie —
          linked by photons, with the middle node Bob acting as a swap relay
          so that Alice and Charlie can share entanglement without ever
          exchanging a photon directly. Demonstrated entanglement distribution
          and entanglement swapping in 2021; qubit teleportation between
          non-neighbouring nodes in 2022.
        </p>
        <dl class="hero-meta">
          <div><dt>Operator</dt><dd>QuTech / TU Delft (Hanson group); part of the EU Quantum Internet Alliance flagship</dd></div>
          <div><dt>Location</dt><dd>Delft, Netherlands (single building, three independently-controlled cryogenic stations)</dd></div>
          <div><dt>Year</dt><dd>2021 (Pompili et al.); 2022 teleportation follow-up (Hermans et al.)</dd></div>
          <div><dt>Technology</dt><dd>Entanglement-based; NV-centre memory nodes; phase-stabilised optical links; auxiliary memory qubit and local quantum logic at each node</dd></div>
          <div><dt>Scale</dt><dd>Three nodes on the lab bench; the optical links are short (metres) but architecturally complete</dd></div>
          <div><dt>Status</dt><dd>Research demonstration</dd></div>
          <div><dt>Commercial model</dt><dd>Academic / EU Quantum Internet Alliance research</dd></div>
        </dl>
      </header>

      <section id="what" data-nav-section>
        <h2>What it is</h2>
        <p>
          Each of the three nodes is an NV centre in diamond — a nitrogen atom
          adjacent to a lattice vacancy — used as the communication qubit,
          with a nearby nuclear spin as a robust memory qubit and local
          quantum-gate primitive. Alice ↔ Bob and Bob ↔ Charlie share
          phase-stabilised optical links; entanglement is heralded between
          neighbour pairs, then Bob performs a Bell-state measurement on his
          two communication qubits to swap the entanglement so Alice and
          Charlie end up sharing a Bell pair.<SourceNote id="pompili-science-2021" />
        </p>
        <p>
          The 2022 follow-up upgraded the protocol to deterministic qubit
          teleportation between non-neighbours: Alice teleports an arbitrary
          unknown qubit state to Charlie using only locally-shared Bell pairs
          and classical communication through Bob, with no direct optical
          link between Alice and Charlie.<SourceNote id="hermans-nature-2022" />
          That is the elementary quantum-internet primitive — sending an
          unknown qubit through a Bell pair plus two classical bits — running
          end-to-end on a real three-node fabric.
        </p>
      </section>

      <section id="papers" data-nav-section>
        <h2>Published papers</h2>
        <p>
          The Delft network is one platform reported across a sequence of
          papers, each removing a barrier the next result depends on.
        </p>
        <div class="exp-table-wrap">
        <table class="exp-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Paper</th>
              <th>Result</th>
              <th>What it implies</th>
            </tr>
          </thead>
          <tbody>
            {papers.map((p) => (
              <tr>
                <td>{p.year}</td>
                <td>{p.paper} <SourceNote id={p.ref} /></td>
                <td>{p.result}</td>
                <td>{p.implies}</td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      </section>

      <section id="verified" data-nav-section>
        <h2>Verified claims</h2>
        <ul class="claim-list">
          <li><strong>First entanglement-based network with three nodes.</strong> Published in Science 372.259 (2021). The "first multinode quantum network of remote solid-state qubits" framing is the authors' own.<SourceNote id="pompili-science-2021" /></li>
          <li><strong>Entanglement distribution + entanglement swapping at Bob.</strong> Both protocols ran on the platform in the 2021 paper.<SourceNote id="pompili-science-2021" /></li>
          <li><strong>2022 follow-up: qubit teleportation between Alice and Charlie.</strong> Reported by Hermans et al., Nature 605.663 (2022). First end-to-end teleportation between non-neighbouring nodes.<SourceNote id="hermans-nature-2022" /></li>
          <li><strong>NV-centre platform with auxiliary nuclear-spin memory qubits.</strong> The robust memory was essential for the swap protocol to succeed against the heralding-rate / memory-decoherence trade-off.<SourceNote id="pompili-science-2021" /></li>
        </ul>
      </section>

      <section id="caveats" data-nav-section>
        <h2>Things to note</h2>
        <ul class="caveat-list">
          <li><strong>Setting.</strong> The three nodes sit in the same building, with the optical links running on a lab bench. The contribution is architectural rather than geographic.</li>
          <li><strong>Rates.</strong> Heralded entanglement between two NV centres runs at the 1–10 Hz scale; end-to-end teleportation rates in 2022 are lower still. The platform demonstrates the protocols rather than throughput.</li>
          <li><strong>Scope.</strong> The Delft fabric is a kernel demonstration that the building blocks compose; it is not yet offered as a service to other QuTech labs or outside users.</li>
          <li><strong>Relation between the two papers.</strong> The 2022 teleportation result uses the 2021 swap as a subroutine. Both papers describe the same physical platform as sequential milestones on the same setup.</li>
        </ul>
      </section>

      <section id="related" data-nav-section>
        <h2>Related entries</h2>
        <ul class="related-list">
          <li><a href={url("/entanglement")}>Entanglement and Bell pairs</a> — the resource being distributed.</li>
          <li><a href={url("/swapping")}>Entanglement swapping</a> — the Bob-side protocol used to link Alice and Charlie.</li>
          <li><a href={url("/teleportation")}>Quantum teleportation</a> — the 2022 follow-up's demonstrated protocol.</li>
          <li><a href={url("/memories")}>Quantum memories</a> — the NV / nuclear-spin combination Delft uses.</li>
          <li><a href={url("/repeaters")}>Quantum repeaters</a> — the architecture this is a kernel demonstration of.</li>
          <li><a href={url("/case-studies/knaut-boston")}>Knaut Boston-metro demo</a> — sibling matter-qubit deployment, on installed urban fibre.</li>
        </ul>
      </section>

    </Stack>
  </Center>
</Infographic>

